---
import Analytics from '../../../components/Analytics.astro';

export function getStaticPaths() {
  return [
    {
      params: { target: 'blank-router' },
      props: {
        title: 'Blank Router moved to V2 Skill-only',
        description: 'Redirecting this legacy link to the supported V2 Skill-only installation guide.',
        destination: '/Workflow-skill-router/guides/install-skill/',
        eventName: 'legacy_blank_router_redirect',
      },
    },
    {
      params: { target: 'reference-template' },
      props: {
        title: 'Reference Template moved to V2',
        description: 'Redirecting this legacy link to the V1-to-V2 migration guide.',
        destination: '/Workflow-skill-router/guides/migrate-v1-to-v2/',
        eventName: 'legacy_reference_template_redirect',
      },
    },
    {
      params: { target: 'full-source' },
      props: {
        title: 'Full Source Archive moved to V2 Plugin',
        description: 'Redirecting this legacy link to the supported V2 Plugin installation guide.',
        destination: '/Workflow-skill-router/guides/install-plugin/',
        eventName: 'legacy_full_source_redirect',
      },
    },
    {
      params: { target: 'release' },
      props: {
        title: 'Open Latest Release',
        description: 'Redirecting to the latest GitHub Release.',
        destination: 'https://github.com/eric861129/Workflow-skill-router/releases',
        eventName: 'readme_release_click',
      },
    },
    {
      params: { target: 'github' },
      props: {
        title: 'Open GitHub Repository',
        description: 'Redirecting to the GitHub repository.',
        destination: 'https://github.com/eric861129/Workflow-skill-router',
        eventName: 'readme_github_click',
      },
    },
  ];
}

const { title, description, destination, eventName } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`1;url=${destination}`} />
    <meta name="robots" content="noindex" />
    <title>{title} | Workflow Skill Router</title>
    <Analytics />
    <style>
      :root {
        color-scheme: dark light;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      body {
        display: grid;
        min-height: 100vh;
        margin: 0;
        place-items: center;
        color: #f7fbff;
        background: #08111f;
      }

      main {
        width: min(34rem, calc(100vw - 2rem));
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 8px;
        padding: 1.25rem;
        background: rgba(255, 255, 255, 0.06);
      }

      h1 {
        margin: 0 0 0.5rem;
        font-size: 1.35rem;
        line-height: 1.2;
      }

      p {
        color: #b9c7d8;
      }

      a {
        color: #7dd3fc;
        font-weight: 700;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>{title}</h1>
      <p>{description}</p>
      <p><a href={destination}>Continue manually</a></p>
    </main>
    <script define:vars={{ destination, eventName }}>
      const redirect = () => window.location.replace(destination);
      if (typeof window.plausible === 'function') {
        window.plausible(eventName, { callback: redirect });
        window.setTimeout(redirect, 700);
      } else {
        window.setTimeout(redirect, 250);
      }
    </script>
  </body>
</html>
