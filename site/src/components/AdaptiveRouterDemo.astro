---
import demo from '../data/router-demo-v2.generated.json';
import '../styles/adaptive-router-demo.css';

interface Props { locale: 'en' | 'zh-TW'; initialPreset?: string }

const { locale, initialPreset = 'small-auto' } = Astro.props;
const copy = locale === 'zh-TW'
  ? {
      eyebrow: 'V2 ROUTING FLIGHT RECORDER',
      title: '逐步檢查 Router 的每個決策',
      signal: 'CORE 產生 · UI 唯讀',
      scenario: '情境',
      request: '請求',
      mcp: 'MCP 呼叫',
      decision: '決策',
      graph: '工作圖',
      audit: '稽核軌跡',
      evidence: '證據邊界',
      approve: '同意輔助',
      reject: '拒絕輔助',
    }
  : {
      eyebrow: 'V2 ROUTING FLIGHT RECORDER',
      title: 'Inspect every routing decision',
      signal: 'CORE-DERIVED · READ-ONLY UI',
      scenario: 'Scenario',
      request: 'Request',
      mcp: 'MCP calls',
      decision: 'Decision',
      graph: 'Work graph',
      audit: 'Audit trail',
      evidence: 'Evidence boundary',
      approve: 'Approve support',
      reject: 'Reject support',
    };
---

<section
  id="router-demo"
  class="adaptive-router-demo"
  data-router-demo
  data-locale={locale}
  data-initial={initialPreset}
  aria-labelledby="router-demo-title"
>
  <header class="router-demo-header">
    <span>{copy.eyebrow}</span>
    <h2 id="router-demo-title">{copy.title}</h2>
    <div class="router-demo-signal"><i aria-hidden="true"></i>{copy.signal}</div>
  </header>

  <div class="router-demo-section-index" aria-hidden="true">
    <span>01 {copy.scenario}</span>
    <span>02 {copy.request}</span>
    <span>03 {copy.mcp}</span>
    <span>04 {copy.decision}</span>
    <span>05 {copy.graph}</span>
    <span>06 {copy.audit}</span>
    <span>07 {copy.evidence}</span>
  </div>

  <div
    class="router-demo-tabs"
    role="tablist"
    aria-label={locale === 'zh-TW' ? '路由情境' : 'Routing scenarios'}
  >
    {demo.presets.map((preset, index) => (
      <button
        type="button"
        role="tab"
        aria-selected={preset.id === initialPreset ? 'true' : 'false'}
        tabindex={preset.id === initialPreset ? 0 : -1}
        data-testid={`demo-preset-${preset.id}`}
        data-preset={preset.id}
      >
        <span>{String(index + 1).padStart(2, '0')}</span>
        {preset.title[locale]}
      </button>
    ))}
  </div>

  <div class="router-demo-console">
    <article class="router-demo-request router-demo-panel">
      <header><span>02</span><h3>{copy.request}</h3></header>
      <p data-demo-request></p>
      <div class="router-demo-actions" data-demo-consent hidden>
        <button type="button" data-testid="demo-consent-approve" data-branch="support-approved">{copy.approve}</button>
        <button type="button" data-testid="demo-consent-reject" data-branch="support-rejected">{copy.reject}</button>
      </div>
    </article>

    <article class="router-demo-mcp router-demo-panel">
      <header><span>03</span><h3>{copy.mcp}</h3></header>
      <div class="router-demo-mcp-list" data-demo-mcp></div>
    </article>

    <article class="router-demo-decision router-demo-panel">
      <header><span>04</span><h3>{copy.decision}</h3></header>
      <div class="router-demo-envelope"><span>ENVELOPE</span><strong data-demo-envelope></strong></div>
      <div class="router-demo-route" data-demo-route></div>
      <div class="router-demo-status" data-testid="demo-status" aria-live="polite"></div>
      <div class="router-demo-coverage" data-testid="demo-explicit-coverage"></div>
    </article>

    <article class="router-demo-graph router-demo-panel">
      <header><span>05</span><h3>{copy.graph}</h3></header>
      <div data-demo-graph></div>
    </article>

    <article class="router-demo-audit router-demo-panel">
      <header><span>06</span><h3>{copy.audit}</h3></header>
      <ol data-demo-events></ol>
    </article>

    <article class="router-demo-evidence router-demo-panel">
      <header><span>07</span><h3>{copy.evidence}</h3></header>
      <div data-demo-evidence></div>
      <div data-demo-evaluation></div>
    </article>
  </div>

  <script type="application/json" data-demo-payload set:html={JSON.stringify(demo)}></script>
</section>
<script>import '../scripts/adaptive-router-demo';</script>
