          <div class="wsr-template-grid">
            {text.templateHighlights.map(([title, body]) => (
              <a class="wsr-template-pill" href={`${rootPath}/examples/template-skill-catalog/`}>
                <span>{title}</span>
                <p>{body}</p>
              </a>
            ))}
          </div>
          <div class="wsr-template-actions">
            <a class="wsr-text-link" href="https://github.com/eric861129/Workflow-skill-router/raw/main/downloads/workflow-skill-router-template.zip">{isZh ? '下載範本包' : 'Download template package'}</a>
            <a class="wsr-text-link" href="https://github.com/eric861129/Workflow-skill-router/tree/main/examples/template-skill-catalog">{isZh ? '查看 GitHub source' : 'View GitHub source'}</a>
          </div>
        </div>
        <div class="wsr-outcome-carousel" data-wsr-carousel>
          <div class="wsr-carousel-controls">
            <button type="button" data-wsr-prev aria-label={isZh ? '上一個成果' : 'Previous outcome'}>‹</button>
            <h3>{text.outcomesTitle}</h3>
            <button type="button" data-wsr-next aria-label={isZh ? '下一個成果' : 'Next outcome'}>›</button>
          </div>
          <div class="wsr-carousel-track" data-wsr-track>
            {text.outcomes.map(([title, body]) => (
              <article class="wsr-outcome-card wsr-motion-image">
                <h4>{title}</h4>
                <p>{body}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="validator" class="wsr-section wsr-section-light">
    <div class="wsr-shell wsr-validator">
      <div>
        <h2>{text.validatorTitle}</h2>
        <p>{text.validatorCopy}</p>
      </div>
      <div class="wsr-command-card">
        <pre><code>{text.validatorCommand}</code></pre>
        <a class="wsr-text-link" href={`${rootPath}/reference/validator/`}>{isZh ? '查看 Validator CLI' : 'View Validator CLI'}</a>
      </div>
    </div>
  </section>

  <section class="wsr-final-cta">
    <div class="wsr-shell">
      <h2>{text.finalTitle}</h2>
      <p>{text.finalCopy}</p>
      <div class="wsr-hero-actions">
        <a class="wsr-button wsr-button-primary" href={repoUrl} target="_blank" rel="noreferrer">{text.star}</a>
        <a class="wsr-button wsr-button-secondary" href={`${rootPath}/guides/downloads/`}>{text.download}</a>
      </div>
    </div>
  </section>
</main>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.querySelectorAll('[data-wsr-route-demo]').forEach((demo) => {
    const dataNode = demo.querySelector('[data-route-demo-json]');
    const buttons = Array.from(demo.querySelectorAll('[data-demo-index]'));
    const promptNode = demo.querySelector('[data-demo-prompt]');
    const outputNode = demo.querySelector('[data-demo-output]');
    const copyButton = demo.querySelector('[data-wsr-copy-route]');
    const scenarios = JSON.parse(dataNode?.textContent || '[]');

    const formatRoute = (scenario) =>
      `Route: ${scenario.route}\nUse SKILL: ${scenario.skills}\nReason: ${scenario.reason}`;

    const renderScenario = (index) => {
      const scenario = scenarios[index];
      if (!scenario || !promptNode || !outputNode) return;
      promptNode.textContent = scenario.prompt;
      outputNode.textContent = formatRoute(scenario);
      buttons.forEach((button) => {
        const isActive = Number(button.getAttribute('data-demo-index')) === index;
        button.setAttribute('aria-selected', String(isActive));
      });
      if (copyButton instanceof HTMLButtonElement) {
        copyButton.textContent = copyButton.dataset.copyLabel || copyButton.textContent || '';
      }
    };

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        renderScenario(Number(button.getAttribute('data-demo-index') || 0));
      });
    });

    copyButton?.addEventListener('click', async () => {
      if (!outputNode?.textContent || !(copyButton instanceof HTMLButtonElement)) return;
      try {
        await navigator.clipboard.writeText(outputNode.textContent);
        copyButton.textContent = copyButton.dataset.copiedLabel || 'Copied';
        window.setTimeout(() => {
          copyButton.textContent = copyButton.dataset.copyLabel || 'Copy route';
        }, 1400);
      } catch {
        copyButton.textContent = copyButton.dataset.copyLabel || 'Copy route';
      }
    });
  });

  document.querySelectorAll('[data-wsr-carousel]').forEach((carousel) => {
    const track = carousel.querySelector('[data-wsr-track]');
    const prev = carousel.querySelector('[data-wsr-prev]');
    const next = carousel.querySelector('[data-wsr-next]');

    const scrollByCard = (direction) => {
      if (!track) return;
      const card = track.querySelector('.wsr-outcome-card');
      const distance = card ? card.getBoundingClientRect().width + 16 : 280;
      track.scrollBy({ left: direction * distance, behavior: reduceMotion ? 'auto' : 'smooth' });
    };

    prev?.addEventListener('click', () => scrollByCard(-1));
    next?.addEventListener('click', () => scrollByCard(1));
  });

  if (!reduceMotion) {
    gsap.registerPlugin(ScrollTrigger);

    gsap.from('.wsr-hero-title, .wsr-hero-copy, .wsr-hero-actions, .wsr-route-showcase', {
      y: 28,
      opacity: 0,
      duration: 0.9,
      ease: 'power3.out',
      stagger: 0.08,
    });

    gsap.utils.toArray('.wsr-motion-image').forEach((element) => {
      gsap.fromTo(
        element,
        { scale: 0.92, opacity: 0.62 },
        {
          scale: 1,
          opacity: 1,
          ease: 'none',
          scrollTrigger: {
            trigger: element,
            start: 'top 88%',
            end: 'bottom 20%',
            scrub: true,
          },
        },
      );
    });

    const media = gsap.matchMedia();
    media.add('(min-width: 980px)', () => {
      ScrollTrigger.create({
        trigger: '.wsr-proof',
        start: 'top top',
        end: 'bottom bottom',
        pin: '.wsr-proof-pin',
        pinSpacing: false,
      });
    });
  }
</script>
