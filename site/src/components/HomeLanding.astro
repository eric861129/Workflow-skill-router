---
import AdaptiveRouterDemo from './AdaptiveRouterDemo.astro';
type Locale = 'en' | 'zh-tw';

const locale = (Astro.props.locale ?? 'en') as Locale;
const repoUrl = 'https://github.com/eric861129/Workflow-skill-router';
const rootPath = locale === 'zh-tw' ? '/Workflow-skill-router/zh-tw' : '/Workflow-skill-router';
const isZh = locale === 'zh-tw';
const alternateLocalePath = isZh ? '/Workflow-skill-router/' : '/Workflow-skill-router/zh-tw/';
const alternateLocaleLabel = isZh ? 'EN' : '繁中';
const localeSwitchLabel = isZh ? '切換到英文版' : 'Switch to Traditional Chinese';
const themeToggleLabel = isZh ? '切換深淺模式' : 'Toggle color theme';
const themeLabels = isZh
  ? { light: '淺色', dark: '深色' }
  : { light: 'Light', dark: 'Dark' };

const text = {
  en: {
    nav: ['Why it works', 'Examples', 'Proof'],
    navLinks: ['#why-it-works', '#examples', '#validator'],
    star: 'View on GitHub',
    quickstart: 'Start in 30 seconds',
    downloadBlank: 'Download blank package',
    download: 'Downloads',
    showcase: 'Routing showcase',
    gifAlt: 'A fuzzy request becoming a small routing output',
    heroTitle: 'Skill selection governance before the work begins',
    heroCopy:
      'Workflow Skill Router addresses one layer of agent sprawl: skill selection sprawl. It gives agents a small, reviewable routing decision before work starts.',
    positioningLabel: 'Positioning',
    positioningTitle: 'A skill selection layer, not a permission system',
    positioningCopy:
      'It does not replace scope contracts, runtime permissions, approval policies, or tool access controls. It only selects the smallest useful skill set from skills that already exist and are already allowed.',
    routeLabel: 'Routing output',
    route:
      'Route: Frontend / Vue / UI > Browser regression > Rendered behavior\nUse SKILL: vue-expert, systematic-debugging, playwright\nReason: vue-expert handles component reactivity; systematic-debugging isolates the cause; playwright captures the regression.',
    introTitle: 'A sharper operating layer for multi-skill agents',
    introCopy:
      'Most agents do not fail because they lack tools. They fail because every related workflow competes for attention. This router turns task intent into a small, reviewable skill set before execution starts, then leaves authorization and approval to your existing governance layers.',
    introLink: 'Read the customization guide',
    processLabel: 'How the router thinks',
    processSteps: [
      [
        'Task shape',
        'Classify the work before choosing tools',
        'The router first separates task nature, work stage, and technical domain so the agent does not treat every request as generic implementation work.',
      ],
      [
        'Primary owner',
        'Choose exactly one skill to lead',
        'A Primary skill owns the main reasoning path. Supporting skills can help, but they should not compete for control of the task.',
      ],
      [
        'Focused support',
        'Add only the skills that reduce risk',
        'Routes stay small: usually one Primary skill plus one to three Supporting skills for APIs, databases, browser checks, docs, CI, or release work.',
      ],
    ],
    processNoteTitle: 'The result is easier to review before execution',
    processNote:
      'Instead of asking the agent to remember every workflow at once, the user sees a short routing contract and can correct it before files are edited.',
    contractLink: 'View routing contract',
    templateLink: 'Explore Reference Template',
    examplesTitle: 'A reference template for designing your own router',
    examplesCopy:
      'The example is no longer a second product to choose. It shows one public-safe catalog so readers can learn the structure, then adapt Blank Router to their own skills.',
    templateHighlights: [
      ['Public-safe skills', 'System, planning, architecture, API, backend, database, frontend, docs, DevOps, brand, and product skills.'],
      ['Practical route catalog', 'Routes are grouped by real engineering categories with one Primary skill and focused Supporting skills.'],
      ['Source-first proof', 'Every section links back to the GitHub folder and the exact sample route files behind the site.'],
    ],
    templateCode:
      'Database / Performance / Slow query\nPrimary: database-optimizer\nSupporting: sql-pro, systematic-debugging',
    outcomesTitle: 'Designed for visible outcomes',
    outcomes: [
      ['Less context noise', 'A route is narrow enough for the user to correct before the agent edits files.'],
      ['Faster onboarding', 'A new user can download the template, inspect the catalog, and adapt routes to their own agent environment.'],
      ['Safer sharing', 'Public examples stay generic while private overlays can keep organization-specific rules local.'],
    ],
    validatorTitle: 'Proof before publish',
    validatorCopy:
      'The proof flow checks router structure, scans the sample skill catalog, validates public route cases, evaluates route quality, and runs the unit tests before the repo is shared.',
    proofStats: [
      ['80', 'routing scenarios'],
      ['12', 'route cases'],
      ['0%', 'violation rate'],
    ],
    validatorCommand: `# 1. Validate router structure
python scripts/validate-router.py starter/workflow-skill-router
python scripts/validate-router.py examples/template-skill-catalog

# 2. Scan skill catalog
python scripts/scan-skills.py ./sample-skills \\
  --out /tmp/skill-index.json \\
  --markdown /tmp/skill-index.md \\
  --warnings /tmp/skill-warnings.md \\
  --suggest-tree /tmp/suggested-skill-tree.md \\
  --fail-on-private \\
  --fail-on-duplicates

# 3. Evaluate routing quality
python scripts/evaluate-routing.py \\
  --scenarios evaluation/scenarios.example.jsonl \\
  --predictions evaluation/predictions.example.jsonl \\
  --report /tmp/routing-report.md \\
  --json-report /tmp/routing-report.json \\
  --fail-on-violations \\
  --strict

python -m unittest discover -s tests`,
    finalTitle: 'Make skill routing a reusable open-source pattern',
    finalCopy:
      'Open the repository, inspect the starter, and follow releases if the pattern fits your agent workflow.',
  },
  'zh-tw': {
    nav: ['為什麼有效', '範例', '驗證'],
    navLinks: ['#why-it-works', '#examples', '#validator'],
    star: '查看 GitHub',
    quickstart: '30 秒開始',
    downloadBlank: '下載空白套件',
    download: '下載套件',
    showcase: '案例展示',
    gifAlt: '模糊需求轉成小而可檢查 routing output 的短動畫',
    heroTitle: 'AI Agent 開工前，先治理 Skill 選擇',
    heroCopy:
      'Workflow Skill Router 處理的是 Agent sprawl 裡的「Skill 選擇失控」問題。它讓 Agent 在任務開始前，先做一個小而可審查的 routing decision。',
    positioningLabel: '專案定位',
    positioningTitle: '它是 skill selection layer，不是權限系統',
    positioningCopy:
      '它不取代 scope contracts、runtime permissions、approval policies 或 tool access controls。它只會從已存在、已允許的 skills 中，選出最小必要組合。',
    routeLabel: 'Routing output',
    route:
      'Route: 前端 / Vue / UI > 瀏覽器回歸 > 畫面呈現行為\nUse SKILL: vue-expert, systematic-debugging, playwright\nReason: vue-expert 處理 component 與 reactivity；systematic-debugging 釐清真正原因；playwright 補上可重複的回歸驗證。',
    introTitle: '讓多技能 Agent 有清楚入口',
    introCopy:
      'Agent 通常不是缺工具，而是每個相關 workflow 都在搶注意力。這個 router 會先把任務意圖整理成小而清楚、可被使用者修正的 skill set，再把授權與核准交回既有治理層。',
    introLink: '閱讀客製化指南',
    processLabel: 'Router 的判斷方式',
    processSteps: [
      [
        '任務形狀',
        '先分類工作，再選工具',
        'Router 會先拆出任務性質、工作階段與技術領域，避免 Agent 把所有需求都當成一般實作任務處理。',
      ],
      [
        'Primary owner',
        '只選一個主要 SKILL 負責',
        'Primary skill 負責主要推理路徑；Supporting skills 可以協助，但不應該互相搶主導權。',
      ],
      [
        '聚焦支援',
        '只加入真正降低風險的 SKILL',
        'Route 會保持小而清楚：通常是一個 Primary skill，加上一到三個處理 API、資料庫、瀏覽器驗證、文件、CI 或 release 的 Supporting skills。',
      ],
    ],
    processNoteTitle: '重點是讓執行前就能被檢查',
    processNote:
      '使用者看到的是一份短短的 routing contract，可以在 Agent 修改檔案前先修正方向，而不是讓 Agent 一次背著所有 workflow 往前衝。',
    contractLink: '查看 routing contract',
    templateLink: '查看 Reference Template',
    examplesTitle: '用一份參考範本，設計自己的 Router',
    examplesCopy:
      '範例不是另一個要照抄的成品。Template Skill Catalog 只示範 public-safe skills 如何被分類與 routing，方便你回頭用 Blank Router 做自己的版本。',
    templateHighlights: [
      ['Public-safe skills', '包含 system、規劃、架構、API、後端、資料庫、前端、文件、DevOps、品牌與產品相關 SKILL。'],
      ['實戰 route catalog', '依常見工程分類整理，每條 route 都有一個 Primary skill 與聚焦的 Supporting skills。'],
      ['Source-first proof', '每個區塊都能連回 GitHub folder，以及站台背後實際使用的 sample route files。'],
    ],
    templateCode:
      '資料庫 / 效能 / 慢查詢\nPrimary: database-optimizer\nSupporting: sql-pro, systematic-debugging',
    outcomesTitle: '為看得見的成果設計',
    outcomes: [
      ['降低上下文噪音', 'Route 小到使用者可以在 Agent 修改檔案前先修正方向。'],
      ['更快導入', '新使用者可以下載範本、檢查 catalog，再把 routes 改成自己的 Agent 環境。'],
      ['更安全分享', '公開範例保持 generic，組織內規則則可以放在 private overlay。'],
    ],
    validatorTitle: '發布前先驗證',
    validatorCopy:
      'Proof flow 會先驗證 router 結構、掃描 sample skill catalog、驗證 public route cases、評估 routing quality，並執行 unit tests，再分享 repo。',
    proofStats: [
      ['80', 'routing scenarios'],
      ['12', 'route cases'],
      ['0%', 'violation rate'],
    ],
    validatorCommand: `# 1. 驗證 router 結構
python scripts/validate-router.py starter/workflow-skill-router
python scripts/validate-router.py examples/template-skill-catalog

# 2. 掃描 skill catalog
python scripts/scan-skills.py ./sample-skills \\
  --out /tmp/skill-index.json \\
  --markdown /tmp/skill-index.md \\
  --warnings /tmp/skill-warnings.md \\
  --suggest-tree /tmp/suggested-skill-tree.md \\
  --fail-on-private \\
  --fail-on-duplicates

# 3. 評估 routing quality
python scripts/evaluate-routing.py \\
  --scenarios evaluation/scenarios.example.jsonl \\
