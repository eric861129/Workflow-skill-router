---
type Locale = 'en' | 'zh-tw';

const locale = (Astro.props.locale ?? 'en') as Locale;
const repoUrl = 'https://github.com/eric861129/Workflow-skill-router';
const assetRoot = '/Workflow-skill-router';
const rootPath = locale === 'zh-tw' ? '/Workflow-skill-router/zh-tw' : '/Workflow-skill-router';
const isZh = locale === 'zh-tw';
const alternateLocalePath = isZh ? '/Workflow-skill-router/' : '/Workflow-skill-router/zh-tw/';
const alternateLocaleLabel = isZh ? 'EN' : '繁中';
const localeSwitchLabel = isZh ? '切換到英文版' : 'Switch to Traditional Chinese';
const themeToggleLabel = isZh ? '切換深淺模式' : 'Toggle color theme';
const themeLabels = isZh
  ? { light: '淺色', dark: '深色' }
  : { light: 'Light', dark: 'Dark' };

const text = {
  en: {
    nav: ['Why it works', 'Examples', 'Proof'],
    navLinks: ['#why-it-works', '#examples', '#validator'],
    star: 'View on GitHub',
    quickstart: 'Start in 30 seconds',
    downloadBlank: 'Download blank package',
    download: 'Downloads',
    showcase: 'Routing showcase',
    gifAlt: 'A fuzzy request becoming a small routing output',
    heroTitle: 'AI agent skill routing before the work begins',
    heroCopy:
      'Workflow Skill Router is a practical routing pattern for Codex Skills and multi-skill agents: choose one primary skill, add focused support, and keep complex tasks out of context overload.',
    routeLabel: 'Routing output',
    route:
      'Route: Frontend / Vue / UI > Browser regression > Rendered behavior\nUse SKILL: vue-expert, systematic-debugging, playwright\nReason: vue-expert handles component reactivity; systematic-debugging isolates the cause; playwright captures the regression.',
    introTitle: 'A sharper operating layer for multi-skill agents',
    introCopy:
      'Most agents do not fail because they lack tools. They fail because every related workflow competes for attention. This router turns task intent into a small, reviewable skill set before execution starts.',
    introLink: 'Read the customization guide',
    processLabel: 'How the router thinks',
    processSteps: [
      [
        'Task shape',
        'Classify the work before choosing tools',
        'The router first separates task nature, work stage, and technical domain so the agent does not treat every request as generic implementation work.',
      ],
      [
        'Primary owner',
        'Choose exactly one skill to lead',
        'A Primary skill owns the main reasoning path. Supporting skills can help, but they should not compete for control of the task.',
      ],
      [
        'Focused support',
        'Add only the skills that reduce risk',
        'Routes stay small: usually one Primary skill plus one to three Supporting skills for APIs, databases, browser checks, docs, CI, or release work.',
      ],
    ],
    processNoteTitle: 'The result is easier to review before execution',
    processNote:
      'Instead of asking the agent to remember every workflow at once, the user sees a short routing contract and can correct it before files are edited.',
    contractLink: 'View routing contract',
    templateLink: 'Explore Reference Template',
    examplesTitle: 'A reference template for designing your own router',
    examplesCopy:
      'The example is no longer a second product to choose. It shows one public-safe catalog so readers can learn the structure, then adapt Blank Router to their own skills.',
    templateHighlights: [
      ['Public-safe skills', 'System, planning, architecture, API, backend, database, frontend, docs, DevOps, brand, and product skills.'],
      ['Practical route catalog', 'Routes are grouped by real engineering categories with one Primary skill and focused Supporting skills.'],
      ['Source-first proof', 'Every section links back to the GitHub folder and the exact sample route files behind the site.'],
    ],
    templateCode:
      'Database / Performance / Slow query\nPrimary: database-optimizer\nSupporting: sql-pro, systematic-debugging',
    outcomesTitle: 'Designed for visible outcomes',
    outcomes: [
      ['Less context noise', 'A route is narrow enough for the user to correct before the agent edits files.'],
      ['Faster onboarding', 'A new user can download the template, inspect the catalog, and adapt routes to their own agent environment.'],
      ['Safer sharing', 'Public examples stay generic while private overlays can keep organization-specific rules local.'],
    ],
    validatorTitle: 'Proof before publish',
    validatorCopy:
      'The proof flow checks router structure, scans the sample skill catalog, evaluates route quality, and runs the unit tests before the repo is shared.',
    proofStats: [
      ['30', 'routing scenarios'],
      ['19', 'unit tests'],
      ['100', 'a11y / SEO gate'],
    ],
    validatorCommand: `# 1. Validate router structure
python scripts/validate-router.py starter/workflow-skill-router
python scripts/validate-router.py examples/template-skill-catalog

# 2. Scan skill catalog
python scripts/scan-skills.py ./sample-skills \\
  --out /tmp/skill-index.json \\
  --markdown /tmp/skill-index.md \\
  --warnings /tmp/skill-warnings.md \\
  --suggest-tree /tmp/suggested-skill-tree.md \\
  --fail-on-private \\
  --fail-on-duplicates

# 3. Evaluate routing quality
python scripts/evaluate-routing.py \\
  --scenarios evaluation/scenarios.example.jsonl \\
  --predictions evaluation/predictions.example.jsonl \\
  --report /tmp/routing-report.md \\
  --json-report /tmp/routing-report.json \\
  --fail-on-violations \\
  --strict

python -m unittest discover -s tests`,
    finalTitle: 'Make skill routing a reusable open-source pattern',
    finalCopy:
      'Open the repository, inspect the starter, and follow releases if the pattern fits your agent workflow.',
  },
  'zh-tw': {
    nav: ['為什麼有效', '範例', '驗證'],
    navLinks: ['#why-it-works', '#examples', '#validator'],
    star: '查看 GitHub',
    quickstart: '30 秒開始',
    downloadBlank: '下載空白套件',
    download: '下載套件',
    showcase: '案例展示',
    gifAlt: '模糊需求轉成小而可檢查 routing output 的短動畫',
    heroTitle: 'AI Agent 開工前，先完成 skill routing',
    heroCopy:
      'Workflow Skill Router 是給 Codex Skills 與多技能 Agent 使用的實戰 routing pattern：先選一個 primary skill，再補上聚焦的 supporting skills，讓複雜任務不要被上下文噪音淹沒。',
    routeLabel: 'Routing output',
    route:
      'Route: 前端 / Vue / UI > 瀏覽器回歸 > 畫面呈現行為\nUse SKILL: vue-expert, systematic-debugging, playwright\nReason: vue-expert 處理 component 與 reactivity；systematic-debugging 釐清真正原因；playwright 補上可重複的回歸驗證。',
    introTitle: '讓多技能 Agent 有清楚入口',
    introCopy:
      'Agent 通常不是缺工具，而是每個相關 workflow 都在搶注意力。這個 router 會先把任務意圖整理成小而清楚、可被使用者修正的 skill set，再開始執行。',
    introLink: '閱讀客製化指南',
    processLabel: 'Router 的判斷方式',
    processSteps: [
      [
        '任務形狀',
        '先分類工作，再選工具',
        'Router 會先拆出任務性質、工作階段與技術領域，避免 Agent 把所有需求都當成一般實作任務處理。',
      ],
      [
        'Primary owner',
        '只選一個主要 SKILL 負責',
        'Primary skill 負責主要推理路徑；Supporting skills 可以協助，但不應該互相搶主導權。',
      ],
      [
        '聚焦支援',
        '只加入真正降低風險的 SKILL',
        'Route 會保持小而清楚：通常是一個 Primary skill，加上一到三個處理 API、資料庫、瀏覽器驗證、文件、CI 或 release 的 Supporting skills。',
      ],
    ],
    processNoteTitle: '重點是讓執行前就能被檢查',
    processNote:
      '使用者看到的是一份短短的 routing contract，可以在 Agent 修改檔案前先修正方向，而不是讓 Agent 一次背著所有 workflow 往前衝。',
    contractLink: '查看 routing contract',
    templateLink: '查看 Reference Template',
    examplesTitle: '用一份參考範本，設計自己的 Router',
    examplesCopy:
      '範例不是另一個要照抄的成品。Template Skill Catalog 只示範 public-safe skills 如何被分類與 routing，方便你回頭用 Blank Router 做自己的版本。',
    templateHighlights: [
      ['Public-safe skills', '包含 system、規劃、架構、API、後端、資料庫、前端、文件、DevOps、品牌與產品相關 SKILL。'],
      ['實戰 route catalog', '依常見工程分類整理，每條 route 都有一個 Primary skill 與聚焦的 Supporting skills。'],
      ['Source-first proof', '每個區塊都能連回 GitHub folder，以及站台背後實際使用的 sample route files。'],
    ],
    templateCode:
      '資料庫 / 效能 / 慢查詢\nPrimary: database-optimizer\nSupporting: sql-pro, systematic-debugging',
    outcomesTitle: '為看得見的成果設計',
    outcomes: [
      ['降低上下文噪音', 'Route 小到使用者可以在 Agent 修改檔案前先修正方向。'],
      ['更快導入', '新使用者可以下載範本、檢查 catalog，再把 routes 改成自己的 Agent 環境。'],
      ['更安全分享', '公開範例保持 generic，組織內規則則可以放在 private overlay。'],
    ],
    validatorTitle: '發布前先驗證',
    validatorCopy:
      'Proof flow 會先驗證 router 結構、掃描 sample skill catalog、評估 routing quality，並執行 unit tests，再分享 repo。',
    proofStats: [
      ['30', 'routing scenarios'],
      ['19', 'unit tests'],
      ['100', 'a11y / SEO gate'],
    ],
    validatorCommand: `# 1. 驗證 router 結構
python scripts/validate-router.py starter/workflow-skill-router
python scripts/validate-router.py examples/template-skill-catalog

# 2. 掃描 skill catalog
python scripts/scan-skills.py ./sample-skills \\
  --out /tmp/skill-index.json \\
  --markdown /tmp/skill-index.md \\
  --warnings /tmp/skill-warnings.md \\
  --suggest-tree /tmp/suggested-skill-tree.md \\
  --fail-on-private \\
  --fail-on-duplicates

# 3. 評估 routing quality
python scripts/evaluate-routing.py \\
  --scenarios evaluation/scenarios.example.jsonl \\
  --predictions evaluation/predictions.example.jsonl \\
  --report /tmp/routing-report.md \\
  --json-report /tmp/routing-report.json \\
  --fail-on-violations \\
  --strict

python -m unittest discover -s tests`,
    finalTitle: '把 skill routing 打磨成可重用的開源 pattern',
    finalCopy:
      '打開 GitHub repo，檢查 starter。如果這個 pattern 適合你的 Agent workflow，可以透過 releases 追蹤後續更新。',
  },
}[locale];

const demoText = isZh
  ? {
      eyebrow: 'Interactive route demo',
      title: '點一個任務，馬上看 Agent 應該載入哪些 SKILL',
      body: '這個 demo 把模糊需求轉成可檢查的 routing output。讀者可以先理解決策，再去下載 Blank Router 或研究 Reference Template。',
      prompt: 'User prompt',
      output: 'Routing output',
      copy: '複製 route',
      copied: '已複製',
      copyInstall: '複製安裝指令',
      installCopied: '指令已複製',
      star: '查看 GitHub repo',
      template: '查看 Template Skill Catalog',
    }
  : {
      eyebrow: 'Interactive route demo',
      title: 'Pick a task and watch the agent choose its skill set',
      body: 'This demo turns a fuzzy prompt into a reviewable routing output before any agent starts editing files.',
      prompt: 'User prompt',
      output: 'Routing output',
      copy: 'Copy route',
      copied: 'Copied',
      copyInstall: 'Copy install command',
      installCopied: 'Install command copied',
      star: 'View GitHub repo',
      template: 'View Template Skill Catalog',
    };

const routeDemoScenarios = isZh
  ? [
      {
        label: 'API 合約同步',
        prompt: '新增 customer settings endpoint，更新 OpenAPI，重新產生 TypeScript client，並補上合約測試。',
        route: 'API / 合約生命週期 > 後端到前端同步',
        skills: 'api-designer, openapi-contract-generation-skill, openapi-to-typescript, qa-test-planner',
        reason:
          'api-designer 穩定 endpoint 語意；openapi-contract-generation-skill 管理 schema diff；openapi-to-typescript 更新前端型別；qa-test-planner 補齊合約測試。',
      },
      {
        label: 'Vue 瀏覽器回歸',
        prompt: 'Vue 表單重新整理後會遺失已選值，請在瀏覽器重現並補一個 regression check。',
        route: '前端 / Vue / UI > 瀏覽器回歸 > 狀態保存',
        skills: 'vue-expert, systematic-debugging, playwright, qa-test-planner',
        reason:
          'vue-expert 處理 component 與 reactivity；systematic-debugging 找出真正原因；playwright 建立可重複瀏覽器檢查；qa-test-planner 定義驗收覆蓋。',
      },
      {
        label: '資料庫效能風險',
        prompt: '替帳號異動新增 audit tables，並確認 admin activity query 在 migration 後仍然夠快。',
        route: '資料庫 / Schema 與效能 > Migration 加查詢檢查',
        skills: 'database-schema-designer, sql-pro, database-optimizer, qa-test-planner',
        reason:
          'database-schema-designer 設計 audit tables；sql-pro 保持 SQL 清楚；database-optimizer 檢查 runtime cost；qa-test-planner 規劃 migration 回歸測試。',
      },
      {
        label: 'PR 與 CI 收尾',
        prompt: 'Review 一個 auth 相關 PR，處理 review feedback，並在 merge 前修好失敗的 CI checks。',
        route: 'Review / CI readiness > 權限敏感變更',
        skills: 'receiving-code-review, systematic-debugging, qa-test-planner, commit-work',
        reason:
          'receiving-code-review 將 feedback 轉成修改；systematic-debugging 隔離 CI 失敗原因；qa-test-planner 保護 auth 表面；commit-work 準備乾淨提交。',
      },
    ]
  : [
      {
        label: 'API contract sync',
        prompt:
          'Add a customer settings endpoint, update OpenAPI, regenerate the TypeScript client, and define the contract tests.',
        route: 'API / Contract lifecycle > Backend-to-frontend sync',
        skills: 'api-designer, openapi-contract-generation-skill, openapi-to-typescript, qa-test-planner',
        reason:
          'api-designer stabilizes endpoint semantics; openapi-contract-generation-skill manages schema diff; openapi-to-typescript updates frontend types; qa-test-planner defines contract coverage.',
      },
      {
        label: 'Vue browser regression',
        prompt: 'A Vue form loses selected values after refresh. Reproduce it in the browser and add a regression check.',
        route: 'Frontend / Vue / UI > Browser regression > State persistence',
        skills: 'vue-expert, systematic-debugging, playwright, qa-test-planner',
        reason:
          'vue-expert handles component and reactivity behavior; systematic-debugging finds the real cause; playwright captures a repeatable browser check; qa-test-planner defines acceptance coverage.',
      },
      {
        label: 'Database performance risk',
        prompt: 'Add audit tables for account changes and make sure the admin activity query stays fast after the migration.',
        route: 'Database / Schema and performance > Migration plus query review',
        skills: 'database-schema-designer, sql-pro, database-optimizer, qa-test-planner',
        reason:
          'database-schema-designer models the audit tables; sql-pro keeps queries clear; database-optimizer checks runtime cost; qa-test-planner covers migration regressions.',
      },
      {
        label: 'PR and CI closeout',
        prompt: 'Review an auth-related PR, address review feedback, and fix the failing CI checks before merge.',
        route: 'Review / CI readiness > Security-sensitive change',
        skills: 'receiving-code-review, systematic-debugging, qa-test-planner, commit-work',
        reason:
          'receiving-code-review turns feedback into action; systematic-debugging isolates CI failures; qa-test-planner protects the auth surface; commit-work prepares a clean final commit.',
      },
    ];

const initialDemo = routeDemoScenarios[0];
---

<main class="wsr-landing" data-wsr-home data-locale={locale}>
  <nav class="wsr-floating-nav" aria-label={isZh ? '首頁導覽' : 'Home navigation'}>
    <a class="wsr-wordmark" href={rootPath + '/'}>
      <span class="wsr-wordmark-mark" aria-hidden="true"></span>
      <span>Workflow Skill Router</span>
    </a>
    <div class="wsr-nav-links">
      {text.nav.map((item, index) => (
        <a href={text.navLinks[index]}>{item}</a>
      ))}
    </div>
    <div class="wsr-nav-actions">
      <a class="wsr-locale-switch" href={alternateLocalePath} aria-label={localeSwitchLabel}>
        {alternateLocaleLabel}
      </a>
      <button
        class="wsr-theme-toggle"
        type="button"
        data-wsr-theme-toggle
        data-light-label={themeLabels.light}
        data-dark-label={themeLabels.dark}
        aria-label={themeToggleLabel}
      >
        <span class="wsr-theme-dot" aria-hidden="true"></span>
        <span data-wsr-theme-label>{themeLabels.dark}</span>
      </button>
      <a class="wsr-nav-star" href={repoUrl} target="_blank" rel="noreferrer" aria-label={text.star}>
        <span class="wsr-star-full">{text.star}</span>
        <span class="wsr-star-short">GitHub</span>
      </a>
    </div>
  </nav>

  <section class="wsr-hero" aria-labelledby="wsr-hero-title">
    <div class="wsr-shell wsr-hero-inner">
      <h1 id="wsr-hero-title" class="wsr-hero-title">{text.heroTitle}</h1>
      <p class="wsr-hero-copy">{text.heroCopy}</p>
      <div class="wsr-hero-actions">
        <a class="wsr-button wsr-button-primary" href={repoUrl} target="_blank" rel="noreferrer">{text.star}</a>
        <a class="wsr-button wsr-button-secondary" href="https://github.com/eric861129/Workflow-skill-router/raw/main/downloads/workflow-skill-router-blank.zip">{text.downloadBlank}</a>
        <a class="wsr-button wsr-button-secondary" href={`${rootPath}/guides/quickstart/`}>{text.quickstart}</a>
      </div>
      <div class="wsr-route-showcase" aria-label={text.routeLabel}>
        <div class="wsr-route-header">
          <span>{text.routeLabel}</span>
          <a href={`${rootPath}/reference/routing-contract/`}>{text.contractLink}</a>
        </div>
        <pre><code>{text.route}</code></pre>
      </div>
      <a class="wsr-hero-demo-gif" href={`${rootPath}/showcase/`}>
        <img
          src={`${assetRoot}/assets/fuzzy-to-route-output.gif`}
          alt={text.gifAlt}
          width="640"
          height="360"
          loading="lazy"
          decoding="async"
        />
        <span>{text.showcase}</span>
      </a>
    </div>
  </section>

  <section id="why-it-works" class="wsr-section wsr-section-light">
    <div class="wsr-shell wsr-section-grid">
      <div>
        <h2>{text.introTitle}</h2>
        <p>{text.introCopy}</p>
        <a class="wsr-text-link" href={`${rootPath}/guides/adoption/`}>{text.introLink}</a>
      </div>
      <div class="wsr-process-panel" aria-label={text.processLabel}>
        <span class="wsr-process-kicker">{text.processLabel}</span>
        <div class="wsr-process-list">
          {text.processSteps.map(([label, title, body], index) => (
            <article class="wsr-process-step">
              <span class="wsr-process-number">{String(index + 1).padStart(2, '0')}</span>
              <div>
                <span class="wsr-process-label">{label}</span>
                <h3>{title}</h3>
                <p>{body}</p>
              </div>
            </article>
          ))}
        </div>
        <div class="wsr-process-note">
          <h3>{text.processNoteTitle}</h3>
          <p>{text.processNote}</p>
          <div class="wsr-process-links">
            <a class="wsr-text-link" href={`${rootPath}/reference/routing-contract/`}>{text.contractLink}</a>
            <a class="wsr-text-link" href={`${rootPath}/showcase/`}>{text.showcase}</a>
            <a class="wsr-text-link" href={`${rootPath}/examples/template-skill-catalog/`}>{text.templateLink}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="route-demo" class="wsr-section wsr-route-demo-section">
    <div class="wsr-shell wsr-route-demo-grid">
      <div>
        <span class="wsr-section-eyebrow">{demoText.eyebrow}</span>
        <h2>{demoText.title}</h2>
        <p>{demoText.body}</p>
        <div class="wsr-demo-actions">
          <a class="wsr-button wsr-button-primary" href={repoUrl} target="_blank" rel="noreferrer">{demoText.star}</a>
          <a class="wsr-button wsr-button-secondary-dark" href={`${rootPath}/examples/template-skill-catalog/`}>{demoText.template}</a>
          <button class="wsr-button wsr-button-secondary-dark" type="button" data-wsr-copy-install data-copy-label={demoText.copyInstall} data-copied-label={demoText.installCopied}>
            {demoText.copyInstall}
          </button>
        </div>
      </div>

      <div class="wsr-route-demo" data-wsr-route-demo>
        <script type="application/json" data-route-demo-json set:html={JSON.stringify(routeDemoScenarios)} />
        <div class="wsr-demo-tabs" role="tablist" aria-label={demoText.eyebrow}>
          {routeDemoScenarios.map((scenario, index) => (
            <button
              type="button"
              role="tab"
              aria-selected={index === 0 ? 'true' : 'false'}
              data-demo-index={index}
            >
              {scenario.label}
            </button>
          ))}
        </div>

        <div class="wsr-demo-card">
          <div class="wsr-demo-prompt">
            <span>{demoText.prompt}</span>
            <p data-demo-prompt>{initialDemo.prompt}</p>
          </div>

          <div class="wsr-demo-output">
            <div class="wsr-route-header">
              <span>{demoText.output}</span>
              <button type="button" data-wsr-copy-route data-copy-label={demoText.copy} data-copied-label={demoText.copied}>
                {demoText.copy}
              </button>
            </div>
            <pre><code data-demo-output>{`Route: ${initialDemo.route}
Use SKILL: ${initialDemo.skills}
Reason: ${initialDemo.reason}`}</code></pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="examples" class="wsr-section wsr-section-dark wsr-proof" data-wsr-pin>
    <div class="wsr-shell wsr-proof-grid">
      <div class="wsr-proof-pin">
        <h2>{text.examplesTitle}</h2>
        <p>{text.examplesCopy}</p>
        <a class="wsr-button wsr-button-secondary-dark" href={`${rootPath}/examples/template-skill-catalog/`}>{text.templateLink}</a>
      </div>
      <div class="wsr-proof-stack">
        <div class="wsr-template-showcase wsr-motion-image">
          <div>
            <span class="wsr-template-kicker">Template Skill Catalog</span>
            <h3>{isZh ? '下載包內容，就是範例內容' : 'The download package is the example'}</h3>
            <p>{isZh ? '讀者不需要在三個情境頁之間猜哪個才是主範本。這裡直接把 template zip 的 public-safe skills 分類成可複製 routes。' : 'Readers no longer need to choose between several scenario pages. This catalog turns the template zip skills into copyable routes.'}</p>
          </div>
          <pre><code>{text.templateCode}</code></pre>
          <div class="wsr-template-grid">
            {text.templateHighlights.map(([title, body]) => (
              <a class="wsr-template-pill" href={`${rootPath}/examples/template-skill-catalog/`}>
                <span>{title}</span>
                <p>{body}</p>
              </a>
            ))}
          </div>
          <div class="wsr-template-actions">
            <a class="wsr-text-link" href="https://github.com/eric861129/Workflow-skill-router/raw/main/downloads/workflow-skill-router-template-clean.zip">{isZh ? '下載 Reference Template' : 'Download Reference Template'}</a>
            <a class="wsr-text-link" href="https://github.com/eric861129/Workflow-skill-router/tree/main/examples/template-skill-catalog">{isZh ? '查看 GitHub source' : 'View GitHub source'}</a>
          </div>
        </div>
        <div class="wsr-outcome-carousel" data-wsr-carousel>
          <div class="wsr-carousel-controls">
            <button type="button" data-wsr-prev aria-label={isZh ? '上一個成果' : 'Previous outcome'}>
              <span aria-hidden="true">←</span>
              <span>{isZh ? '上一則' : 'Previous'}</span>
            </button>
            <h3>{text.outcomesTitle}</h3>
            <button type="button" data-wsr-next aria-label={isZh ? '下一個成果' : 'Next outcome'}>
              <span>{isZh ? '下一則' : 'Next'}</span>
              <span aria-hidden="true">→</span>
            </button>
          </div>
          <div class="wsr-carousel-track" data-wsr-track>
            {text.outcomes.map(([title, body]) => (
              <article class="wsr-outcome-card wsr-motion-image">
                <h4>{title}</h4>
                <p>{body}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="validator" class="wsr-section wsr-section-light">
    <div class="wsr-shell wsr-validator">
      <div>
        <h2>{text.validatorTitle}</h2>
        <p>{text.validatorCopy}</p>
        <div class="wsr-proof-stats" aria-label={isZh ? '驗證數字' : 'Validation stats'}>
          {text.proofStats.map(([value, label]) => (
            <span>
              <strong>{value}</strong>
              {label}
            </span>
          ))}
        </div>
      </div>
      <div class="wsr-command-card">
        <pre><code>{text.validatorCommand}</code></pre>
        <a class="wsr-text-link" href={`${rootPath}/reference/validator/`}>{isZh ? '查看驗證工具鏈' : 'View validation toolchain'}</a>
      </div>
    </div>
  </section>

  <section class="wsr-final-cta">
    <div class="wsr-shell">
      <h2>{text.finalTitle}</h2>
      <p>{text.finalCopy}</p>
      <div class="wsr-hero-actions">
        <a class="wsr-button wsr-button-primary" href={repoUrl} target="_blank" rel="noreferrer">{text.star}</a>
        <a class="wsr-button wsr-button-secondary" href={`${rootPath}/guides/downloads/`}>{text.download}</a>
      </div>
    </div>
  </section>
</main>

<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const themeKey = 'starlight-theme';
  const themeQuery = window.matchMedia('(prefers-color-scheme: light)');
  const normalizeTheme = (theme) => (theme === 'light' || theme === 'dark' ? theme : null);
  const storedTheme = () => {
    try {
      return normalizeTheme(localStorage.getItem(themeKey));
    } catch {
      return null;
    }
  };
  const saveTheme = (theme) => {
    try {
      localStorage.setItem(themeKey, theme);
    } catch {
      // The visible theme still changes even when browser storage is unavailable.
    }
  };
  const systemTheme = () => (themeQuery.matches ? 'light' : 'dark');
  const currentTheme = () =>
    storedTheme() ||
    normalizeTheme(document.documentElement.dataset.theme) ||
    systemTheme();

  const updateThemeToggle = (theme) => {
    document.querySelectorAll('[data-wsr-theme-toggle]').forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;
      const label = button.querySelector('[data-wsr-theme-label]');
      if (label) {
        label.textContent = theme === 'light' ? button.dataset.lightLabel || 'Light' : button.dataset.darkLabel || 'Dark';
      }
      button.dataset.theme = theme;
    });
  };

  const applyTheme = (theme) => {
    document.documentElement.dataset.theme = theme;
    saveTheme(theme);
    globalThis.StarlightThemeProvider?.updatePickers?.(theme);
    updateThemeToggle(theme);
  };

  applyTheme(currentTheme());

  document.querySelectorAll('[data-wsr-theme-toggle]').forEach((button) => {
    button.addEventListener('click', () => {
      const nextTheme = currentTheme() === 'dark' ? 'light' : 'dark';
      applyTheme(nextTheme);
    });
  });

  document.querySelectorAll('[data-wsr-route-demo]').forEach((demo) => {
    const dataNode = demo.querySelector('[data-route-demo-json]');
    const buttons = Array.from(demo.querySelectorAll('[data-demo-index]'));
    const promptNode = demo.querySelector('[data-demo-prompt]');
    const outputNode = demo.querySelector('[data-demo-output]');
    const copyButton = demo.querySelector('[data-wsr-copy-route]');
    const scenarios = JSON.parse(dataNode?.textContent || '[]');

    const formatRoute = (scenario) =>
      `Route: ${scenario.route}\nUse SKILL: ${scenario.skills}\nReason: ${scenario.reason}`;

    const renderScenario = (index) => {
      const scenario = scenarios[index];
      if (!scenario || !promptNode || !outputNode) return;
      promptNode.textContent = scenario.prompt;
      outputNode.textContent = formatRoute(scenario);
      buttons.forEach((button) => {
        const isActive = Number(button.getAttribute('data-demo-index')) === index;
        button.setAttribute('aria-selected', String(isActive));
      });
      if (copyButton instanceof HTMLButtonElement) {
        copyButton.textContent = copyButton.dataset.copyLabel || copyButton.textContent || '';
      }
    };

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        renderScenario(Number(button.getAttribute('data-demo-index') || 0));
      });
    });

    copyButton?.addEventListener('click', async () => {
      if (!outputNode?.textContent || !(copyButton instanceof HTMLButtonElement)) return;
      try {
        await navigator.clipboard.writeText(outputNode.textContent);
        copyButton.textContent = copyButton.dataset.copiedLabel || 'Copied';
        window.setTimeout(() => {
          copyButton.textContent = copyButton.dataset.copyLabel || 'Copy route';
        }, 1400);
      } catch {
        copyButton.textContent = copyButton.dataset.copyLabel || 'Copy route';
      }
    });
  });

  document.querySelectorAll('[data-wsr-copy-install]').forEach((button) => {
    button.addEventListener('click', async () => {
      if (!(button instanceof HTMLButtonElement)) return;
      const command = `$Repo = "https://github.com/eric861129/Workflow-skill-router"
$Zip = Join-Path $env:TEMP "workflow-skill-router-blank.zip"
$Validator = Join-Path $env:TEMP "workflow-skill-router-validate-router.py"
$Skills = Join-Path $env:USERPROFILE ".codex\\skills"
Invoke-WebRequest "$Repo/raw/main/downloads/workflow-skill-router-blank.zip" -OutFile $Zip
Invoke-WebRequest "$Repo/raw/main/scripts/validate-router.py" -OutFile $Validator
New-Item -ItemType Directory -Force -Path $Skills | Out-Null
Expand-Archive -Force -Path $Zip -DestinationPath $Skills
python $Validator (Join-Path $Skills "workflow-skill-router")`;
      try {
        await navigator.clipboard.writeText(command);
        button.textContent = button.dataset.copiedLabel || 'Copied';
        window.setTimeout(() => {
          button.textContent = button.dataset.copyLabel || 'Copy install command';
        }, 1400);
      } catch {
        button.textContent = button.dataset.copyLabel || 'Copy install command';
      }
    });
  });

  document.querySelectorAll('[data-wsr-carousel]').forEach((carousel) => {
    const track = carousel.querySelector('[data-wsr-track]');
    const prev = carousel.querySelector('[data-wsr-prev]');
    const next = carousel.querySelector('[data-wsr-next]');

    const scrollByCard = (direction) => {
      if (!track) return;
      const card = track.querySelector('.wsr-outcome-card');
      const distance = card ? card.getBoundingClientRect().width + 16 : 280;
      track.scrollBy({ left: direction * distance, behavior: reduceMotion ? 'auto' : 'smooth' });
    };

    prev?.addEventListener('click', () => scrollByCard(-1));
    next?.addEventListener('click', () => scrollByCard(1));
  });

</script>
