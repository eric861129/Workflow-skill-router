---

<main class="wsr-landing" data-wsr-home data-locale={locale}>
  <nav class="wsr-floating-nav" aria-label={isZh ? '首頁導覽' : 'Home navigation'}>
    <a class="wsr-wordmark" href={rootPath + '/'}>
      <span class="wsr-wordmark-mark" aria-hidden="true"></span>
      <span>Workflow Skill Router</span>
    </a>
    <div class="wsr-nav-links">
      {text.nav.map((item, index) => (
        <a href={text.navLinks[index]}>{item}</a>
      ))}
    </div>
    <a class="wsr-nav-star" href={repoUrl} target="_blank" rel="noreferrer">{text.star}</a>
  </nav>

  <section class="wsr-hero" aria-labelledby="wsr-hero-title">
    <div class="wsr-hero-image" aria-hidden="true"></div>
    <div class="wsr-hero-wash" aria-hidden="true"></div>
    <div class="wsr-shell wsr-hero-inner">
      <h1 id="wsr-hero-title" class="wsr-hero-title">{text.heroTitle}</h1>
      <p class="wsr-hero-copy">{text.heroCopy}</p>
      <div class="wsr-hero-actions">
        <a class="wsr-button wsr-button-primary" href={repoUrl} target="_blank" rel="noreferrer">{text.star}</a>
        <a class="wsr-button wsr-button-secondary" href={`${rootPath}/guides/quickstart/`}>{text.quickstart}</a>
      </div>
      <div class="wsr-route-showcase" aria-label={text.routeLabel}>
        <div class="wsr-route-header">
          <span>{text.routeLabel}</span>
          <a href={`${rootPath}/reference/routing-contract/`}>{text.contractLink}</a>
        </div>
        <pre><code>{text.route}</code></pre>
      </div>
    </div>
  </section>

  <section id="why-it-works" class="wsr-section wsr-section-light">
    <div class="wsr-shell wsr-section-grid">
      <div>
        <h2>{text.introTitle}</h2>
        <p>{text.introCopy}</p>
        <a class="wsr-text-link" href={`${rootPath}/guides/adoption/`}>{text.introLink}</a>
      </div>
      <div class="wsr-process-panel" aria-label={text.processLabel}>
        <span class="wsr-process-kicker">{text.processLabel}</span>
        <div class="wsr-process-list">
          {text.processSteps.map(([label, title, body], index) => (
            <article class="wsr-process-step">
              <span class="wsr-process-number">{String(index + 1).padStart(2, '0')}</span>
              <div>
                <span class="wsr-process-label">{label}</span>
                <h3>{title}</h3>
                <p>{body}</p>
              </div>
            </article>
          ))}
        </div>
        <div class="wsr-process-note">
          <h3>{text.processNoteTitle}</h3>
          <p>{text.processNote}</p>
          <div class="wsr-process-links">
            <a class="wsr-text-link" href={`${rootPath}/reference/routing-contract/`}>{text.contractLink}</a>
            <a class="wsr-text-link" href={`${rootPath}/examples/template-skill-catalog/`}>{text.templateLink}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="route-demo" class="wsr-section wsr-route-demo-section">
    <div class="wsr-shell wsr-route-demo-grid">
      <div>
        <span class="wsr-section-eyebrow">{demoText.eyebrow}</span>
        <h2>{demoText.title}</h2>
        <p>{demoText.body}</p>
        <div class="wsr-demo-actions">
          <a class="wsr-button wsr-button-primary" href={repoUrl} target="_blank" rel="noreferrer">{demoText.star}</a>
          <a class="wsr-button wsr-button-secondary-dark" href={`${rootPath}/examples/template-skill-catalog/`}>{demoText.template}</a>
        </div>
      </div>

      <div class="wsr-route-demo" data-wsr-route-demo>
        <script type="application/json" data-route-demo-json set:html={JSON.stringify(routeDemoScenarios)} />
        <div class="wsr-demo-tabs" role="tablist" aria-label={demoText.eyebrow}>
          {routeDemoScenarios.map((scenario, index) => (
            <button
              type="button"
              role="tab"
              aria-selected={index === 0 ? 'true' : 'false'}
              data-demo-index={index}
            >
              {scenario.label}
