python -m unittest discover -s tests`,
    finalTitle: '把 skill routing 打磨成可重用的開源 pattern',
    finalCopy:
      '打開 GitHub repo，檢查 starter。如果這個 pattern 適合你的 Agent workflow，可以透過 releases 追蹤後續更新。',
  },
}[locale];

const heroText = isZh
  ? {
      eyebrow: 'Codex SKILL / Routing Layer',
      title: '工作開始前，先管好 SKILL 選擇',
      body: '把每個 Codex 任務先收斂成小而可審查的 SKILL route，再開始改檔。',
      primary: '下載 Blank Router',
      secondary: '查看 route 範例',
      explainerLabel: '這個 SKILL 做什麼',
      explainerTitle: '把模糊任務轉成清楚 route',
    }
  : {
      eyebrow: 'Codex SKILL / Routing Layer',
      title: 'Skill selection governance before the work begins',
      body: 'Turn each Codex request into a small, reviewable SKILL route before files change.',
      primary: 'Download Blank Router',
      secondary: 'View routing examples',
      explainerLabel: 'What this SKILL does',
      explainerTitle: 'Turn a messy request into a clear route',
    };

const heroPreview = isZh
  ? {
      requestLabel: '模糊任務',
      request: '幫我修首頁 Hero，讓用戶一眼懂這個 SKILL。',
      routeLabel: '選定的 SKILL route',
      route: [
        ['Primary', 'design-taste-frontend'],
        ['Supporting', 'ui-ux-pro-max'],
        ['Why', '先處理第一印象與可讀性，再檢查 RWD。'],
        ['Boundary', '只選擇 SKILL，不授權工具。'],
      ],
    }
  : {
      requestLabel: 'Messy request',
      request: 'Fix the homepage Hero so first-time users understand this SKILL.',
      routeLabel: 'Selected SKILL route',
      route: [
        ['Primary', 'design-taste-frontend'],
        ['Supporting', 'ui-ux-pro-max'],
        ['Why', 'Clarify first impression, then check responsive readability.'],
        ['Boundary', 'Selects SKILLs only. Tool permissions stay external.'],
      ],
    };
---

<main class="wsr-landing" data-wsr-home data-locale={locale}>
  <nav class="wsr-floating-nav" aria-label={isZh ? '首頁導覽' : 'Home navigation'}>
    <a class="wsr-wordmark" href={rootPath + '/'}>
      <span class="wsr-wordmark-mark" aria-hidden="true"></span>
      <span>Workflow Skill Router</span>
    </a>
    <div class="wsr-nav-links">
      {text.nav.map((item, index) => (
        <a href={text.navLinks[index]}>{item}</a>
      ))}
    </div>
    <div class="wsr-nav-actions">
      <a class="wsr-locale-switch" href={alternateLocalePath} aria-label={localeSwitchLabel}>
        {alternateLocaleLabel}
      </a>
      <button
        class="wsr-theme-toggle"
        type="button"
        data-wsr-theme-toggle
        data-light-label={themeLabels.light}
        data-dark-label={themeLabels.dark}
        aria-label={themeToggleLabel}
      >
        <span class="wsr-theme-dot" aria-hidden="true"></span>
        <span data-wsr-theme-label>{themeLabels.dark}</span>
      </button>
      <a class="wsr-nav-star" href={repoUrl} target="_blank" rel="noreferrer" aria-label={text.star} data-analytics-event="site_nav_github">
        <span class="wsr-star-full">{text.star}</span>
        <span class="wsr-star-short">GitHub</span>
      </a>
    </div>
  </nav>

  <section class="wsr-hero" aria-labelledby="wsr-hero-title">
    <div class="wsr-shell wsr-hero-inner">
      <div class="wsr-hero-copy-block">
        <span class="wsr-hero-eyebrow">{heroText.eyebrow}</span>
        <h1 id="wsr-hero-title" class="wsr-hero-title">{heroText.title}</h1>
        <p class="wsr-hero-copy">{heroText.body}</p>
        <div class="wsr-hero-actions">
          <a class="wsr-button wsr-button-primary" href="https://github.com/eric861129/Workflow-skill-router/raw/main/downloads/workflow-skill-router-blank.zip" data-analytics-event="site_hero_download_blank">{heroText.primary}</a>
          <a class="wsr-button wsr-button-secondary" href={`${rootPath}/showcase/`}>{heroText.secondary}</a>
        </div>
      </div>

      <div id="route-demo" class="wsr-hero-explainer wsr-hero-preview" aria-label={heroText.explainerLabel}>
        <div class="wsr-hero-explainer-header">
          <span>{heroText.explainerLabel}</span>
          <h2>{heroText.explainerTitle}</h2>
        </div>
        <div class="wsr-hero-preview-flow">
          <div class="wsr-hero-request">
            <span>{heroPreview.requestLabel}</span>
            <p>{heroPreview.request}</p>
          </div>
          <div class="wsr-hero-flow-rail" aria-hidden="true">
            <span></span>
          </div>
          <div class="wsr-hero-route-card">
            <span>{heroPreview.routeLabel}</span>
            <div class="wsr-hero-route-list">
              {heroPreview.route.map(([label, value]) => (
                <div>
                  <span>{label}</span>
                  <p>{value}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <AdaptiveRouterDemo locale={isZh ? 'zh-TW' : 'en'} />

  <section id="why-it-works" class="wsr-section wsr-section-light">
    <div class="wsr-shell wsr-section-grid">
      <div>
        <h2>{text.introTitle}</h2>
        <p>{text.introCopy}</p>
        <a class="wsr-text-link" href={`${rootPath}/guides/adoption/`}>{text.introLink}</a>
      </div>
      <div class="wsr-process-panel" aria-label={text.processLabel}>
        <span class="wsr-process-kicker">{text.processLabel}</span>
        <div class="wsr-process-list">
          {text.processSteps.map(([label, title, body], index) => (
            <article class="wsr-process-step">
              <span class="wsr-process-number">{String(index + 1).padStart(2, '0')}</span>
              <div>
                <span class="wsr-process-label">{label}</span>
                <h3>{title}</h3>
                <p>{body}</p>
              </div>
            </article>
          ))}
        </div>
        <div class="wsr-process-note">
          <h3>{text.processNoteTitle}</h3>
          <p>{text.processNote}</p>
          <div class="wsr-process-links">
            <a class="wsr-text-link" href={`${rootPath}/reference/routing-contract/`}>{text.contractLink}</a>
            <a class="wsr-text-link" href={`${rootPath}/showcase/`}>{text.showcase}</a>
            <a class="wsr-text-link" href={`${rootPath}/examples/template-skill-catalog/`}>{text.templateLink}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="examples" class="wsr-section wsr-section-dark wsr-proof" data-wsr-pin>
    <div class="wsr-shell wsr-proof-grid">
      <div class="wsr-proof-pin">
        <h2>{text.examplesTitle}</h2>
        <p>{text.examplesCopy}</p>
        <a class="wsr-button wsr-button-secondary-dark" href={`${rootPath}/examples/template-skill-catalog/`}>{text.templateLink}</a>
      </div>
      <div class="wsr-proof-stack">
        <div class="wsr-template-showcase wsr-motion-image">
          <div>
            <span class="wsr-template-kicker">Template Skill Catalog</span>
            <h3>{isZh ? '下載包內容，就是範例內容' : 'The download package is the example'}</h3>
            <p>{isZh ? '讀者不需要在三個情境頁之間猜哪個才是主範本。這裡直接把 template zip 的 public-safe skills 分類成可複製 routes。' : 'Readers no longer need to choose between several scenario pages. This catalog turns the template zip skills into copyable routes.'}</p>
          </div>
          <pre><code>{text.templateCode}</code></pre>
          <div class="wsr-template-grid">
            {text.templateHighlights.map(([title, body]) => (
              <a class="wsr-template-pill" href={`${rootPath}/examples/template-skill-catalog/`}>
                <span>{title}</span>
                <p>{body}</p>
              </a>
            ))}
          </div>
          <div class="wsr-template-actions">
            <a class="wsr-text-link" href="https://github.com/eric861129/Workflow-skill-router/raw/main/downloads/workflow-skill-router-template-clean.zip">{isZh ? '下載 Reference Template' : 'Download Reference Template'}</a>
            <a class="wsr-text-link" href="https://github.com/eric861129/Workflow-skill-router/tree/main/examples/template-skill-catalog">{isZh ? '查看 GitHub source' : 'View GitHub source'}</a>
          </div>
        </div>
        <div class="wsr-outcome-carousel" data-wsr-carousel>
          <div class="wsr-carousel-controls">
            <button type="button" data-wsr-prev aria-label={isZh ? '上一個成果' : 'Previous outcome'}>
              <span aria-hidden="true">←</span>
              <span>{isZh ? '上一則' : 'Previous'}</span>
            </button>
            <h3>{text.outcomesTitle}</h3>
            <button type="button" data-wsr-next aria-label={isZh ? '下一個成果' : 'Next outcome'}>
              <span>{isZh ? '下一則' : 'Next'}</span>
              <span aria-hidden="true">→</span>
            </button>
          </div>
          <div class="wsr-carousel-track" data-wsr-track>
            {text.outcomes.map(([title, body]) => (
              <article class="wsr-outcome-card wsr-motion-image">
                <h4>{title}</h4>
                <p>{body}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="validator" class="wsr-section wsr-section-light">
    <div class="wsr-shell wsr-validator">
      <div>
        <h2>{text.validatorTitle}</h2>
        <p>{text.validatorCopy}</p>
        <div class="wsr-proof-stats" aria-label={isZh ? '驗證數字' : 'Validation stats'}>
          {text.proofStats.map(([value, label]) => (
            <span>
              <strong>{value}</strong>
              {label}
            </span>
          ))}
        </div>
      </div>
      <div class="wsr-command-card">
        <pre><code>{text.validatorCommand}</code></pre>
        <a class="wsr-text-link" href={`${rootPath}/reference/validator/`}>{isZh ? '查看驗證工具鏈' : 'View validation toolchain'}</a>
      </div>
    </div>
  </section>

  <section class="wsr-final-cta">
    <div class="wsr-shell">
      <h2>{text.finalTitle}</h2>
      <p>{text.finalCopy}</p>
      <div class="wsr-hero-actions">
        <a class="wsr-button wsr-button-primary" href={repoUrl} target="_blank" rel="noreferrer">{text.star}</a>
        <a class="wsr-button wsr-button-secondary" href={`${rootPath}/guides/downloads/`}>{text.download}</a>
      </div>
    </div>
  </section>
</main>

<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const themeKey = 'starlight-theme';
  const themeQuery = window.matchMedia('(prefers-color-scheme: light)');
  const normalizeTheme = (theme) => (theme === 'light' || theme === 'dark' ? theme : null);
  const storedTheme = () => {
    try {
      return normalizeTheme(localStorage.getItem(themeKey));
    } catch {
      return null;
    }
  };
  const saveTheme = (theme) => {
    try {
      localStorage.setItem(themeKey, theme);
    } catch {
      // The visible theme still changes even when browser storage is unavailable.
    }
  };
  const systemTheme = () => (themeQuery.matches ? 'light' : 'dark');
  const currentTheme = () =>
    storedTheme() ||
    normalizeTheme(document.documentElement.dataset.theme) ||
    systemTheme();

  const updateThemeToggle = (theme) => {
    document.querySelectorAll('[data-wsr-theme-toggle]').forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;
      const label = button.querySelector('[data-wsr-theme-label]');
      if (label) {
        label.textContent = theme === 'light' ? button.dataset.lightLabel || 'Light' : button.dataset.darkLabel || 'Dark';
      }
      button.dataset.theme = theme;
    });
  };

  const applyTheme = (theme) => {
    document.documentElement.dataset.theme = theme;
    saveTheme(theme);
    globalThis.StarlightThemeProvider?.updatePickers?.(theme);
    updateThemeToggle(theme);
  };

  applyTheme(currentTheme());

  document.querySelectorAll('[data-wsr-theme-toggle]').forEach((button) => {
    button.addEventListener('click', () => {
      const nextTheme = currentTheme() === 'dark' ? 'light' : 'dark';
      applyTheme(nextTheme);
    });
  });

  document.querySelectorAll('[data-wsr-carousel]').forEach((carousel) => {
    const track = carousel.querySelector('[data-wsr-track]');
    const prev = carousel.querySelector('[data-wsr-prev]');
    const next = carousel.querySelector('[data-wsr-next]');

    const scrollByCard = (direction) => {
      if (!track) return;
      const card = track.querySelector('.wsr-outcome-card');
      const distance = card ? card.getBoundingClientRect().width + 16 : 280;
      track.scrollBy({ left: direction * distance, behavior: reduceMotion ? 'auto' : 'smooth' });
    };

    prev?.addEventListener('click', () => scrollByCard(-1));
    next?.addEventListener('click', () => scrollByCard(1));
  });

</script>
