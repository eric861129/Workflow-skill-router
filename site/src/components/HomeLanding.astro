---
import AdaptiveRouterDemo from './AdaptiveRouterDemo.astro';
type Locale = 'en' | 'zh-tw';

const locale = (Astro.props.locale ?? 'en') as Locale;
const repoUrl = 'https://github.com/eric861129/Workflow-skill-router';
const rootPath = locale === 'zh-tw' ? '/Workflow-skill-router/zh-tw' : '/Workflow-skill-router';
const isZh = locale === 'zh-tw';
const alternateLocalePath = isZh ? '/Workflow-skill-router/' : '/Workflow-skill-router/zh-tw/';
const alternateLocaleLabel = isZh ? 'EN' : '繁中';
const localeSwitchLabel = isZh ? '切換到英文版' : 'Switch to Traditional Chinese';
const themeToggleLabel = isZh ? '切換深淺模式' : 'Toggle color theme';
const themeLabels = isZh
  ? { light: '淺色', dark: '深色' }
  : { light: 'Light', dark: 'Dark' };

const text = {
  en: {
    nav: ['Runtime', 'Envelopes', 'Evidence'],
    navLinks: ['#why-it-works', '#examples', '#validator'],
    star: 'View on GitHub',
    quickstart: 'V2 quickstart',
    downloadBlank: 'Install Plugin + MCP',
    download: 'Install V2',
    showcase: 'Routing showcase',
    gifAlt: 'A fuzzy request becoming a small routing output',
    heroTitle: 'Runtime-aware routing before the work begins',
    heroCopy:
      'Workflow Skill Router V2 chooses a Single, Phased, or Managed Goal envelope from current runtime evidence before work starts.',
    positioningLabel: 'Positioning',
    positioningTitle: 'A routing control plane, not a permission system',
    positioningCopy:
      'It does not replace Host permissions, approval policies, native Goal state, or tool controls. It plans only from capabilities that current evidence can justify.',
    routeLabel: 'Routing output',
    route:
      'Route: Frontend / Vue / UI > Browser regression > Rendered behavior\nUse SKILL: vue-expert, systematic-debugging, playwright\nReason: vue-expert handles component reactivity; systematic-debugging isolates the cause; playwright captures the regression.',
    introTitle: 'Discover what can actually run before routing',
    introCopy:
      'V2 separates installed metadata, Host exposure, authorization, policy eligibility, freshness, and risk. A local file or cached observation never becomes runtime authority by itself.',
    introLink: 'Read Runtime Capability Discovery',
    processLabel: 'How V2 routes work',
    processSteps: [
      [
        'Work envelope',
        'Choose Single, Phased, or Managed Goal',
        'The Router classifies dependencies, verification boundaries, resume needs, and Goal relation before selecting capabilities.',
      ],
      [
        'User authority',
        'Preserve Explicit Skill Lock',
        'Named SKILLs remain authoritative. Support outside the lock stays inactive until the user accepts it.',
      ],
      [
        'Runtime evidence',
        'Activate only what current proof allows',
        'Every selected capability keeps its exposure, authorization, policy, freshness, and risk boundary visible.',
      ],
    ],
    processNoteTitle: 'The result is inspectable before and after execution',
    processNote:
      'The Router declares planned SKILL usage before work, records typed runtime results, and discloses actual usage at completion.',
    contractLink: 'View routing contract',
    templateLink: 'Compare routing envelopes',
    examplesTitle: 'One Router, three work envelopes',
    examplesCopy:
      'Small work stays small, multi-stage work reroutes at phase gates, and durable dependency graphs bind to a Host-owned Goal without pretending local authority.',
    templateHighlights: [
      ['Single', 'One bounded outcome, one verification path, and the smallest justified SKILL set.'],
      ['Phased', 'Each phase selects from fresh evidence and must pass its own verification gate.'],
      ['Managed Goal', 'Durable Work Items and dependencies, while native Goal mutation remains Host-owned.'],
    ],
    templateCode:
      'Request → Runtime Capability Discovery\nEnvelope → Single | Phased | Managed Goal\nResult → plan, gate, evidence, disclosure',
    outcomesTitle: 'Designed for trustworthy outcomes',
    outcomes: [
      ['Less context noise', 'Automatic routing stays minimal and does not add a consent ceremony when no SKILL was named.'],
      ['Honest degradation', 'Unavailable Host or adapter capabilities return typed fallbacks instead of simulated success.'],
      ['Auditable execution', 'Sanitized traces show what was planned, called, rejected, and actually used.'],
    ],
    validatorTitle: 'Evidence before claims',
    validatorCopy:
      'Contract fixtures prove compatibility. Runtime traces prove bundled execution. Real Model Evaluation requires fresh paired attempts, explicit quota authorization, review, and attestation.',
    proofStats: [
      ['10', 'typed MCP tools'],
      ['2', 'local-ready tools'],
      ['72', 'GA behavior attempts'],
    ],
    validatorCommand: `# Inspect truthful runtime readiness
python plugins/workflow-skill-router/runtime/workflow_skill_router.pyz doctor

# Verify generated MCP contracts and V2 docs
node scripts/build-mcp-reference-data.mjs --check
python scripts/check-doc-parity.py

# Run repository tests
$env:PYTHONPATH = (Resolve-Path "packages/router-core/src").Path
python -m unittest discover -s packages/router-core/tests -v
python -m unittest discover -s tests -v`,
    finalTitle: 'Make runtime-aware skill routing reusable',
    finalCopy:
      'Install the Plugin + MCP runtime, or load the standalone SKILL when your Host supports instructions only.',
  },
  'zh-tw': {
    nav: ['Runtime', 'Envelopes', 'Evidence'],
    navLinks: ['#why-it-works', '#examples', '#validator'],
    star: '查看 GitHub',
    quickstart: 'V2 快速開始',
    downloadBlank: '安裝 Plugin + MCP',
    download: '安裝 V2',
    showcase: '案例展示',
    gifAlt: '模糊需求轉成小而可檢查 routing output 的短動畫',
    heroTitle: '工作開始前，先用 runtime evidence 決定 route',
    heroCopy:
      'Workflow Skill Router V2 會依目前 runtime evidence，選擇 Single、Phased 或 Managed Goal envelope。',
    positioningLabel: '專案定位',
    positioningTitle: '它是 routing control plane，不是權限系統',
    positioningCopy:
      '它不取代 Host permissions、approval policies、native Goal state 或 tool controls，只會依目前證據規劃可被合理使用的 capabilities。',
    routeLabel: 'Routing output',
    route:
      'Route: 前端 / Vue / UI > 瀏覽器回歸 > 畫面呈現行為\nUse SKILL: vue-expert, systematic-debugging, playwright\nReason: vue-expert 處理 component 與 reactivity；systematic-debugging 釐清真正原因；playwright 補上可重複的回歸驗證。',
    introTitle: 'Routing 前先確認什麼真的能執行',
    introCopy:
      'V2 會分開判斷 installed metadata、Host exposure、authorization、policy eligibility、freshness 與 risk。本機檔案或 cached observation 不會自行變成 runtime authority。',
    introLink: '閱讀 Runtime Capability Discovery',
    processLabel: 'V2 routing 流程',
    processSteps: [
      [
        '工作 envelope',
        '選擇 Single、Phased 或 Managed Goal',
        'Router 先判斷 dependencies、verification boundaries、resume needs 與 Goal relation，再選擇 capabilities。',
      ],
      [
        '使用者權威',
        '保留 Explicit Skill Lock',
        '使用者指定的 SKILL 維持權威；lock 外的輔助技能在取得同意前保持 inactive。',
      ],
      [
        'Runtime evidence',
        '只啟用目前證據允許的能力',
        '每個 selected capability 都保留其 exposure、authorization、policy、freshness 與 risk boundary。',
      ],
    ],
    processNoteTitle: '執行前後都能被檢查',
    processNote:
      'Router 在工作前宣告預計使用的 SKILL，記錄 typed runtime result，完成後揭露實際使用情況。',
    contractLink: '查看 routing contract',
    templateLink: '比較 routing envelopes',
    examplesTitle: '一個 Router，三種工作 envelope',
    examplesCopy:
      '小型工作保持小型、多階段工作在 phase gate 重新 routing，durable dependency graph 則綁定 Host-owned Goal，不虛構本機 authority。',
    templateHighlights: [
      ['Single', '一個範圍明確的 outcome、一條 verification path，以及最小合理 SKILL 組合。'],
      ['Phased', '每個 phase 都從最新 evidence 選擇，並通過自己的 verification gate。'],
      ['Managed Goal', 'Durable Work Items 與 dependencies；native Goal mutation 仍由 Host 所有。'],
    ],
    templateCode:
      'Request → Runtime Capability Discovery\nEnvelope → Single | Phased | Managed Goal\nResult → plan, gate, evidence, disclosure',
    outcomesTitle: '為可信任的成果設計',
    outcomes: [
      ['降低上下文噪音', '自動 routing 維持最小集合；未指定 SKILL 時不增加多餘 consent ceremony。'],
      ['誠實降級', 'Host 或 adapter 能力不可用時回傳 typed fallback，不模擬成功。'],
      ['可稽核執行', 'Sanitized traces 呈現 plan、call、reject 與實際使用結果。'],
    ],
    validatorTitle: '有證據，才提出主張',
    validatorCopy:
      'Contract fixtures 證明 compatibility，runtime traces 證明 bundled execution。Real Model Evaluation 需要 fresh paired attempts、明確 quota authorization、review 與 attestation。',
    proofStats: [
      ['10', 'typed MCP tools'],
      ['2', 'local-ready tools'],
      ['72', 'GA behavior attempts'],
    ],
    validatorCommand: `# 檢查真實 runtime readiness
python plugins/workflow-skill-router/runtime/workflow_skill_router.pyz doctor

# 驗證 generated MCP contracts 與 V2 docs
node scripts/build-mcp-reference-data.mjs --check
python scripts/check-doc-parity.py

# 執行 repository tests
$env:PYTHONPATH = (Resolve-Path "packages/router-core/src").Path
python -m unittest discover -s packages/router-core/tests -v
python -m unittest discover -s tests -v`,
    finalTitle: '讓 runtime-aware skill routing 成為可重用能力',
    finalCopy:
      '環境支援 runtime 時安裝 Plugin + MCP；只有 instructions 的 Host 則載入獨立 SKILL。',
  },
}[locale];

const heroText = isZh
  ? {
      eyebrow: 'Codex Plugin / MCP / SKILL',
      title: '依 runtime 真實能力，選對工作流程',
      body: '小任務保持單一路徑，多階段逐步驗證，大型 Goal 則建立可恢復的工作圖。',
      primary: '安裝 Plugin + MCP',
      secondary: '純 SKILL 安裝',
      explainerLabel: 'V2 routing outcome',
      explainerTitle: '從 request 到 envelope 與 evidence',
    }
  : {
      eyebrow: 'Codex Plugin / MCP / SKILL',
      title: 'Route work from real runtime capabilities',
      body: 'Keep small tasks single, verify multi-stage work phase by phase, and make large Goals resumable.',
      primary: 'Install Plugin + MCP',
      secondary: 'Install Skill-only',
      explainerLabel: 'V2 routing outcome',
      explainerTitle: 'From request to envelope and evidence',
    };

const heroPreview = isZh
  ? {
      requestLabel: '大型任務',
      request: '繼續跨 API、Web 與 docs 的 migration Goal。',
      routeLabel: 'V2 routing decision',
      route: [
        ['Envelope', 'managed-goal'],
        ['Runtime', 'bundled-local-r0'],
        ['Local-ready', 'plan_work, get_router_status'],
        ['Boundary', 'Scheduling requires verified Host capabilities.'],
      ],
    }
  : {
      requestLabel: 'Large request',
      request: 'Continue the migration Goal across API, Web, and docs.',
      routeLabel: 'V2 routing decision',
      route: [
        ['Envelope', 'managed-goal'],
        ['Runtime', 'bundled-local-r0'],
        ['Local-ready', 'plan_work, get_router_status'],
        ['Boundary', 'Scheduling requires verified Host capabilities.'],
      ],
    };
---

<main class="wsr-landing" data-wsr-home data-locale={locale}>
  <nav class="wsr-floating-nav" aria-label={isZh ? '首頁導覽' : 'Home navigation'}>
    <a class="wsr-wordmark" href={rootPath + '/'}>
      <span class="wsr-wordmark-mark" aria-hidden="true"></span>
      <span>Workflow Skill Router</span>
    </a>
    <div class="wsr-nav-links">
      {text.nav.map((item, index) => (
        <a href={text.navLinks[index]}>{item}</a>
      ))}
    </div>
    <div class="wsr-nav-actions">
      <a class="wsr-locale-switch" href={alternateLocalePath} aria-label={localeSwitchLabel}>
        {alternateLocaleLabel}
      </a>
      <button
        class="wsr-theme-toggle"
        type="button"
        data-wsr-theme-toggle
        data-light-label={themeLabels.light}
        data-dark-label={themeLabels.dark}
        aria-label={themeToggleLabel}
      >
        <span class="wsr-theme-dot" aria-hidden="true"></span>
        <span data-wsr-theme-label>{themeLabels.dark}</span>
      </button>
      <a class="wsr-nav-star" href={repoUrl} target="_blank" rel="noreferrer" aria-label={text.star} data-analytics-event="site_nav_github">
        <span class="wsr-star-full">{text.star}</span>
        <span class="wsr-star-short">GitHub</span>
      </a>
    </div>
  </nav>

  <section class="wsr-hero" aria-labelledby="wsr-hero-title">
    <div class="wsr-shell wsr-hero-inner">
      <div class="wsr-hero-copy-block">
        <span class="wsr-hero-eyebrow">{heroText.eyebrow}</span>
        <h1 id="wsr-hero-title" class="wsr-hero-title">{heroText.title}</h1>
        <p class="wsr-hero-copy">{heroText.body}</p>
        <div class="wsr-hero-actions">
          <a class="wsr-button wsr-button-primary" href={`${rootPath}/guides/install-plugin/`} data-analytics-event="site_hero_install_plugin">{heroText.primary}</a>
          <a class="wsr-button wsr-button-secondary" href={`${rootPath}/guides/install-skill/`}>{heroText.secondary}</a>
        </div>
      </div>

      <div id="route-demo" class="wsr-hero-explainer wsr-hero-preview" aria-label={heroText.explainerLabel}>
        <div class="wsr-hero-explainer-header">
          <span>{heroText.explainerLabel}</span>
          <h2>{heroText.explainerTitle}</h2>
        </div>
        <div class="wsr-hero-preview-flow">
          <div class="wsr-hero-request">
            <span>{heroPreview.requestLabel}</span>
            <p>{heroPreview.request}</p>
          </div>
          <div class="wsr-hero-flow-rail" aria-hidden="true">
            <span></span>
          </div>
          <div class="wsr-hero-route-card">
            <span>{heroPreview.routeLabel}</span>
            <div class="wsr-hero-route-list">
              {heroPreview.route.map(([label, value]) => (
                <div>
                  <span>{label}</span>
                  <p>{value}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <AdaptiveRouterDemo locale={isZh ? 'zh-TW' : 'en'} />

  <section id="why-it-works" class="wsr-section wsr-section-light">
    <div class="wsr-shell wsr-section-grid">
      <div>
        <h2>{text.introTitle}</h2>
        <p>{text.introCopy}</p>
        <a class="wsr-text-link" href={`${rootPath}/concepts/runtime-capability-discovery/`}>{text.introLink}</a>
      </div>
      <div class="wsr-process-panel" aria-label={text.processLabel}>
        <span class="wsr-process-kicker">{text.processLabel}</span>
        <div class="wsr-process-list">
          {text.processSteps.map(([label, title, body], index) => (
            <article class="wsr-process-step">
              <span class="wsr-process-number">{String(index + 1).padStart(2, '0')}</span>
              <div>
                <span class="wsr-process-label">{label}</span>
                <h3>{title}</h3>
                <p>{body}</p>
              </div>
            </article>
          ))}
        </div>
        <div class="wsr-process-note">
          <h3>{text.processNoteTitle}</h3>
          <p>{text.processNote}</p>
          <div class="wsr-process-links">
            <a class="wsr-text-link" href={`${rootPath}/reference/routing-contract/`}>{text.contractLink}</a>
            <a class="wsr-text-link" href={`${rootPath}/showcase/`}>{text.showcase}</a>
            <a class="wsr-text-link" href={`${rootPath}/concepts/routing-envelopes/`}>{text.templateLink}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="examples" class="wsr-section wsr-section-dark wsr-proof" data-wsr-pin>
    <div class="wsr-shell wsr-proof-grid">
      <div class="wsr-proof-pin">
        <h2>{text.examplesTitle}</h2>
        <p>{text.examplesCopy}</p>
        <a class="wsr-button wsr-button-secondary-dark" href={`${rootPath}/concepts/routing-envelopes/`}>{text.templateLink}</a>
      </div>
      <div class="wsr-proof-stack">
        <div class="wsr-template-showcase wsr-motion-image">
          <div>
            <span class="wsr-template-kicker">Single / Phased / Managed Goal</span>
            <h3>{isZh ? '工作形狀決定 envelope' : 'Work shape decides the envelope'}</h3>
            <p>{isZh ? 'Router 不會因為需求很長就強迫使用 Goal，而是依 dependencies、resume needs、risk 與 verification boundaries 做決策。' : 'The Router does not force a Goal because a request is long. Dependencies, resume needs, risk, and verification boundaries drive the decision.'}</p>
          </div>
          <pre><code>{text.templateCode}</code></pre>
          <div class="wsr-template-grid">
            {text.templateHighlights.map(([title, body]) => (
              <a class="wsr-template-pill" href={`${rootPath}/concepts/routing-envelopes/`}>
                <span>{title}</span>
                <p>{body}</p>
              </a>
            ))}
          </div>
          <div class="wsr-template-actions">
            <a class="wsr-text-link" href={`${rootPath}/guides/install-plugin/`}>{isZh ? '安裝 Plugin + MCP' : 'Install Plugin + MCP'}</a>
            <a class="wsr-text-link" href={`${rootPath}/guides/install-skill/`}>{isZh ? '安裝純 SKILL' : 'Install Skill-only'}</a>
          </div>
        </div>
        <div class="wsr-outcome-carousel" data-wsr-carousel>
          <div class="wsr-carousel-controls">
            <button type="button" data-wsr-prev aria-label={isZh ? '上一個成果' : 'Previous outcome'}>
              <span aria-hidden="true">←</span>
              <span>{isZh ? '上一則' : 'Previous'}</span>
            </button>
            <h3>{text.outcomesTitle}</h3>
            <button type="button" data-wsr-next aria-label={isZh ? '下一個成果' : 'Next outcome'}>
              <span>{isZh ? '下一則' : 'Next'}</span>
              <span aria-hidden="true">→</span>
            </button>
          </div>
          <div class="wsr-carousel-track" data-wsr-track>
            {text.outcomes.map(([title, body]) => (
              <article class="wsr-outcome-card wsr-motion-image">
                <h4>{title}</h4>
                <p>{body}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="validator" class="wsr-section wsr-section-light">
    <div class="wsr-shell wsr-validator">
      <div>
        <h2>{text.validatorTitle}</h2>
        <p>{text.validatorCopy}</p>
        <div class="wsr-proof-stats" aria-label={isZh ? '驗證數字' : 'Validation stats'}>
          {text.proofStats.map(([value, label]) => (
            <span>
              <strong>{value}</strong>
              {label}
            </span>
          ))}
        </div>
      </div>
      <div class="wsr-command-card">
        <pre><code>{text.validatorCommand}</code></pre>
        <a class="wsr-text-link" href={`${rootPath}/concepts/evaluation-evidence/`}>{isZh ? '查看 evidence contract' : 'View the evidence contract'}</a>
      </div>
    </div>
  </section>

  <section class="wsr-final-cta">
    <div class="wsr-shell">
      <h2>{text.finalTitle}</h2>
      <p>{text.finalCopy}</p>
      <div class="wsr-hero-actions">
        <a class="wsr-button wsr-button-primary" href={repoUrl} target="_blank" rel="noreferrer">{text.star}</a>
        <a class="wsr-button wsr-button-secondary" href={`${rootPath}/guides/quickstart/`}>{text.download}</a>
      </div>
    </div>
  </section>
</main>

<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const themeKey = 'starlight-theme';
  const themeQuery = window.matchMedia('(prefers-color-scheme: light)');
  const normalizeTheme = (theme) => (theme === 'light' || theme === 'dark' ? theme : null);
  const storedTheme = () => {
    try {
      return normalizeTheme(localStorage.getItem(themeKey));
    } catch {
      return null;
    }
  };
  const saveTheme = (theme) => {
    try {
      localStorage.setItem(themeKey, theme);
    } catch {
      // The visible theme still changes even when browser storage is unavailable.
    }
  };
  const systemTheme = () => (themeQuery.matches ? 'light' : 'dark');
  const currentTheme = () =>
    storedTheme() ||
    normalizeTheme(document.documentElement.dataset.theme) ||
    systemTheme();

  const updateThemeToggle = (theme) => {
    document.querySelectorAll('[data-wsr-theme-toggle]').forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;
      const label = button.querySelector('[data-wsr-theme-label]');
      if (label) {
        label.textContent = theme === 'light' ? button.dataset.lightLabel || 'Light' : button.dataset.darkLabel || 'Dark';
      }
      button.dataset.theme = theme;
    });
  };

  const applyTheme = (theme) => {
    document.documentElement.dataset.theme = theme;
    saveTheme(theme);
    globalThis.StarlightThemeProvider?.updatePickers?.(theme);
    updateThemeToggle(theme);
  };

  applyTheme(currentTheme());

  document.querySelectorAll('[data-wsr-theme-toggle]').forEach((button) => {
    button.addEventListener('click', () => {
      const nextTheme = currentTheme() === 'dark' ? 'light' : 'dark';
      applyTheme(nextTheme);
    });
  });

  document.querySelectorAll('[data-wsr-carousel]').forEach((carousel) => {
    const track = carousel.querySelector('[data-wsr-track]');
    const prev = carousel.querySelector('[data-wsr-prev]');
    const next = carousel.querySelector('[data-wsr-next]');

    const scrollByCard = (direction) => {
      if (!track) return;
      const card = track.querySelector('.wsr-outcome-card');
      const distance = card ? card.getBoundingClientRect().width + 16 : 280;
      track.scrollBy({ left: direction * distance, behavior: reduceMotion ? 'auto' : 'smooth' });
    };

    prev?.addEventListener('click', () => scrollByCard(-1));
    next?.addEventListener('click', () => scrollByCard(1));
  });

</script>
