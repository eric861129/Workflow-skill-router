---
import MobileTableOfContents from 'virtual:starlight/components/MobileTableOfContents';
import TableOfContents from 'virtual:starlight/components/TableOfContents';

const locale = Astro.locals.starlightRoute.locale || 'root';
const isZh = locale === 'zh-tw';
const basePath = isZh ? '/Workflow-skill-router/zh-tw' : '/Workflow-skill-router';
const repoUrl = 'https://github.com/eric861129/Workflow-skill-router';

const copy = isZh
  ? {
      eyebrow: '開源分享',
      title: '查看開源專案',
      body: '打開 repo、下載 Blank Router，或參考一套 routing 範例。',
      star: '查看 GitHub',
      download: '下載套件',
    }
  : {
      eyebrow: 'Open source',
      title: 'Explore the project',
      body: 'Open the repo, download Blank Router, or study a routing reference.',
      star: 'View on GitHub',
      download: 'Downloads',
    };
---

{
  Astro.locals.starlightRoute.toc && (
    <>
      <div class="lg:sl-hidden">
        <MobileTableOfContents />
      </div>
      <div class="right-sidebar-panel sl-hidden lg:sl-block">
        <div class="sl-container">
          <TableOfContents />
          <aside class="wsr-doc-cta" aria-label={copy.title}>
            <span>{copy.eyebrow}</span>
            <h2>{copy.title}</h2>
            <p>{copy.body}</p>
            <a class="wsr-doc-cta-primary" href={repoUrl} target="_blank" rel="noreferrer">
              {copy.star}
            </a>
            <a class="wsr-doc-cta-secondary" href={`${basePath}/guides/downloads/`}>
              {copy.download}
            </a>
          </aside>
        </div>
      </div>
    </>
  )
}
