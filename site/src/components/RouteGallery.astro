---
import galleryData from '../data/route-cases.generated.json';

type Locale = 'en' | 'zh-tw';

const locale = (Astro.props.locale ?? 'en') as Locale;
const isZh = locale === 'zh-tw';
const labels = isZh
  ? {
      intro:
        '這些案例是 public-safe 的 canonical route cases，展示模糊請求如何收斂成一個 Primary skill 與少量 Supporting skills。',
      domain: 'Domain',
      allDomains: '全部 domain',
      tags: 'Tags',
      allTags: '全部 tags',
      selected: '選用技能',
      omitted: '刻意不選',
      reason: '原因',
      source: '來源 JSON',
      safety: 'Public safety',
      empty: '沒有符合條件的 route case。',
      issueCta: '提交 route case',
    }
  : {
      intro:
        'These public-safe canonical route cases show how fuzzy requests become one Primary skill plus focused Supporting skills.',
      domain: 'Domain',
      allDomains: 'All domains',
      tags: 'Tags',
      allTags: 'All tags',
      selected: 'Selected skills',
      omitted: 'Omitted on purpose',
      reason: 'Reason',
      source: 'Source JSON',
      safety: 'Public safety',
      empty: 'No route cases match the current filters.',
      issueCta: 'Submit a route case',
    };

const cases = galleryData.cases;
const domains = galleryData.domains;
const tags = galleryData.tags;
const repoCaseUrl = (sourcePath: string) => `https://github.com/eric861129/Workflow-skill-router/blob/main/${sourcePath}`;
const issueUrl = 'https://github.com/eric861129/Workflow-skill-router/issues/new?template=route-case.yml';
---

<section class="wsr-route-gallery" data-wsr-route-gallery>
  <div class="wsr-gallery-intro">
    <p>{labels.intro}</p>
    <a
      class="wsr-inline-cta"
      href={issueUrl}
      data-analytics-event="route_case_issue_cta"
    >
      {labels.issueCta}
    </a>
  </div>

  <div class="wsr-gallery-controls" aria-label="Route case filters">
    <label>
      <span>{labels.domain}</span>
      <select data-gallery-domain>
        <option value="">{labels.allDomains}</option>
        {domains.map((domain) => <option value={domain}>{domain}</option>)}
      </select>
    </label>

    <div class="wsr-gallery-tag-controls" role="group" aria-label={labels.tags}>
      <button type="button" class="is-active" data-gallery-tag="" aria-pressed="true">
        {labels.allTags}
      </button>
      {
        tags.map((tag) => (
          <button type="button" data-gallery-tag={tag} aria-pressed="false">
            {tag}
          </button>
        ))
      }
    </div>
  </div>

  <div class="wsr-gallery-grid">
    {
      cases.map((routeCase) => (
        <article
          class="wsr-route-card"
          data-gallery-card
          data-domain={routeCase.domain}
          data-tags={routeCase.tags.join(' ')}
        >
          <div class="wsr-route-card-heading">
            <span>{routeCase.domain}</span>
            <h2>{routeCase.title}</h2>
          </div>
          <p class="wsr-route-task">{routeCase.task}</p>
          <p>{routeCase.context}</p>

          <div class="wsr-route-path">{routeCase.route.path}</div>

          <div class="wsr-skill-list">
            <h3>{labels.selected}</h3>
            <ul>
              <li>
                <strong>Primary:</strong> <code>{routeCase.route.primary}</code>
              </li>
              {
                routeCase.route.supporting.map((skill) => (
                  <li>
                    <strong>Supporting:</strong> <code>{skill}</code>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="wsr-route-reason">
            <h3>{labels.reason}</h3>
            <p>{routeCase.route.reason}</p>
          </div>

          <details class="wsr-omitted-skills">
            <summary>{labels.omitted}</summary>
            <ul>
              {
                routeCase.omitted_skills.map((item) => (
                  <li>
                    <code>{item.skill}</code>: {item.reason}
                  </li>
                ))
              }
            </ul>
          </details>

          <div class="wsr-route-footer">
            <span>{labels.safety}: {routeCase.public_safety.review_notes}</span>
            <a href={repoCaseUrl(routeCase.source_path)}>{labels.source}</a>
          </div>
        </article>
      ))
    }
  </div>

  <p class="wsr-gallery-empty" data-gallery-empty hidden>{labels.empty}</p>
</section>

<script>
  const galleries = document.querySelectorAll('[data-wsr-route-gallery]');

  for (const gallery of galleries) {
    const domainSelect = gallery.querySelector('[data-gallery-domain]');
    const tagButtons = [...gallery.querySelectorAll('[data-gallery-tag]')];
    const cards = [...gallery.querySelectorAll('[data-gallery-card]')];
    const empty = gallery.querySelector('[data-gallery-empty]');
    let selectedTag = '';

    const applyFilters = () => {
      const selectedDomain = domainSelect?.value ?? '';
      let visibleCount = 0;

      for (const card of cards) {
        const domainMatches = !selectedDomain || card.dataset.domain === selectedDomain;
        const tagSet = new Set((card.dataset.tags ?? '').split(' ').filter(Boolean));
        const tagMatches = !selectedTag || tagSet.has(selectedTag);
        const visible = domainMatches && tagMatches;
        card.toggleAttribute('hidden', !visible);
        if (visible) visibleCount += 1;
      }

      if (empty) empty.hidden = visibleCount > 0;
    };

    domainSelect?.addEventListener('change', applyFilters);
    for (const button of tagButtons) {
      button.addEventListener('click', () => {
        selectedTag = button.dataset.galleryTag ?? '';
        for (const tagButton of tagButtons) {
          const active = tagButton === button;
          tagButton.classList.toggle('is-active', active);
          tagButton.setAttribute('aria-pressed', String(active));
        }
        applyFilters();
      });
    }
  }
</script>
