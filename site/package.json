{
  "name": "workflow-skill-router-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "assets:demo": "node scripts/generate-demo-assets.mjs",
    "assets:demo:check": "node scripts/generate-demo-assets.mjs --check",
    "assets:social": "node scripts/generate-social-assets.mjs",
    "assets:social:check": "node scripts/generate-social-assets.mjs --check",
    "audit:lighthouse": "npm run build && node scripts/lighthouse-audit.mjs",
    "test:site:smoke": "playwright test --project=chromium-smoke",
    "test:site:visual": "playwright test --project=chromium-visual",
    "test:site:update-snapshots": "playwright test --project=chromium-visual --update-snapshots"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.41.1",
    "astro": "^6.4.7"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "chrome-launcher": "^1.2.1",
    "lighthouse": "^13.4.0"
  }
}
