        "phased-08",
        "goal-01",
        "goal-02",
        "goal-03",
        "goal-04",
        "goal-05",
        "goal-06"
      ]
    },
    "verifier": {
      "path": "pilots/verify_restricted_manifest.py",
      "success_code": "pilot-binding-valid",
      "public_output_fields": ["valid", "code"],
      "required_before_task_1": true
    },
    "claim_boundary": "Commitments prove reviewed pre-binding and support later audit; they do not expose task content or replace human review that each input is a real task."
