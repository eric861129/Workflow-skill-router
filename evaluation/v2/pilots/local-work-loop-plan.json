  "task_binding_policy": {
    "distinct_real_task_per_slot": true,
    "freeze_all_inputs_before_first_task": true,
    "synthetic_or_dry_run_is_countable": false
  },
  "restricted_binding_manifest": {
    "schema": "pilots/restricted-binding-manifest.schema.json",
    "created_before_task_1": true,
    "independently_reviewed_before_task_1": true,
    "exact_binding_records": 20,
    "commitment_scheme": "wsr-beta5-pilot-hmac-v1",
    "secret_storage": "restricted-reviewer-access-only",
    "public_commitments_are_reversible": false,
    "human_review_of_real_task_status_required": true,
    "public_safe_attestation_fields": [
      "binding_manifest_commitment",
      "task_set_commitment",
      "reviewer_attestation_commitment"
    ],
    "commitment_input_contract": {
      "specification": "wsr-beta5-pilot-hmac-v1",
      "run_secret_bytes": 32,
      "output": "hmac-sha256:<lowercase 64 hex>",
      "message_prefix": "UTF-8 workflow-skill-router/beta5-pilot/v1",
      "separator": "0x00",
      "field_encoding": "ASCII(decimal byte_length) + 0x3A + UTF-8 field bytes",
      "implicit_json_serialization": false,
      "implicit_unicode_normalization": false,
      "locale_dependent_behavior": false,
      "domain_fields": {
        "task-identity": ["run_id", "slot_id", "task_identity"],
        "source-identity": ["run_id", "slot_id", "source_identity"],
        "profile-identity": ["run_id", "slot_id", "profile_id", "profile_revision_digest"],
        "binding-record": ["run_id", "slot_id", "task_commitment", "source_commitment", "profile_commitment_or_empty", "profile_revision_digest_or_empty", "manual_flag", "no_explicit_flag", "explicit_lock_flag", "resume_flag"],
        "task-set": ["run_id", "20 binding_record_commitments in frozen order"],
        "reviewer-attestation": ["run_id", "source_revision", "runtime_package_digest", "protocol_digest", "task_set_commitment", "reviewer_id", "attested_at", "reviewed_before_task_1", "real_task_status_human_reviewed", "commitments_verified_with_run_secret"],
        "binding-manifest": ["run_id", "frozen_at", "source_revision", "runtime_package_digest", "protocol_digest", "task_set_commitment", "reviewer_attestation_commitment", "20 binding_record_commitments in frozen order"]
      },
      "boolean_encoding": {"true": "true", "false": "false"},
      "task_set_order": [
