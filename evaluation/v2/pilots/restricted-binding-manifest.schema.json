{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "workflow-skill-router/restricted-pilot-binding-manifest/1.0",
  "title": "Restricted beta.5 Pilot binding manifest",
  "description": "Private pre-execution bindings. The instance belongs in restricted evidence and must never be published.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "execution_status",
    "run_id",
    "frozen_at",
    "protocol_digest",
    "source_revision",
    "runtime_package_digest",
    "commitment_scheme",
    "bindings",
    "binding_manifest_commitment",
    "task_set_commitment",
    "reviewer_attestation"
  ],
  "properties": {
    "schema_version": {
      "const": "workflow-skill-router/restricted-pilot-binding-manifest/1.0"
    },
    "execution_status": {
      "const": "restricted-binding-frozen-before-task-1"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]{7,127}$"
    },
    "frozen_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$",
      "format": "date-time",
      "description": "Canonical UTC instant when the reviewed binding manifest became frozen."
    },
    "protocol_digest": {
      "$ref": "#/$defs/sha256Digest"
    },
    "source_revision": {
      "type": "string",
      "minLength": 7,
      "maxLength": 128
    },
    "runtime_package_digest": {
      "$ref": "#/$defs/sha256Digest"
    },
    "commitment_scheme": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "specification",
        "secret_length_bytes",
        "secret_storage",
        "publicly_reversible"
      ],
      "properties": {
        "specification": {
          "const": "wsr-beta5-pilot-hmac-v1"
        },
        "secret_length_bytes": {
          "const": 32
        },
        "secret_storage": {
          "const": "restricted-reviewer-access-only"
        },
        "publicly_reversible": {
          "const": false
        }
      }
    },
    "bindings": {
      "type": "array",
      "minItems": 20,
      "maxItems": 20,
      "uniqueItems": true,
      "prefixItems": [
        {"allOf": [{"$ref": "#/$defs/bindingRecord"}, {"properties": {"slot_id": {"const": "single-01"}, "profile_binding": {"$ref": "#/$defs/profileOff"}, "metric_population_flags": {"$ref": "#/$defs/flagsNoExplicit"}}}]},
        {"allOf": [{"$ref": "#/$defs/bindingRecord"}, {"properties": {"slot_id": {"const": "single-02"}, "profile_binding": {"$ref": "#/$defs/profileOff"}, "metric_population_flags": {"$ref": "#/$defs/flagsNoExplicit"}}}]},
        {"allOf": [{"$ref": "#/$defs/bindingRecord"}, {"properties": {"slot_id": {"const": "single-03"}, "profile_binding": {"$ref": "#/$defs/profileOff"}, "metric_population_flags": {"$ref": "#/$defs/flagsNoExplicit"}}}]},
        {"allOf": [{"$ref": "#/$defs/bindingRecord"}, {"properties": {"slot_id": {"const": "single-04"}, "profile_binding": {"$ref": "#/$defs/profileOff"}, "metric_population_flags": {"$ref": "#/$defs/flagsNoExplicit"}}}]},
        {"allOf": [{"$ref": "#/$defs/bindingRecord"}, {"properties": {"slot_id": {"const": "single-05"}, "profile_binding": {"$ref": "#/$defs/profileOff"}, "metric_population_flags": {"$ref": "#/$defs/flagsNoExplicit"}}}]},
        {"allOf": [{"$ref": "#/$defs/bindingRecord"}, {"properties": {"slot_id": {"const": "single-06"}, "profile_binding": {"$ref": "#/$defs/profileOff"}, "metric_population_flags": {"$ref": "#/$defs/flagsNoExplicit"}}}]},
        {"allOf": [{"$ref": "#/$defs/bindingRecord"}, {"properties": {"slot_id": {"const": "phased-01"}, "profile_binding": {"$ref": "#/$defs/profileOn"}, "metric_population_flags": {"$ref": "#/$defs/flagsExplicitResume"}}}]},
        {"allOf": [{"$ref": "#/$defs/bindingRecord"}, {"properties": {"slot_id": {"const": "phased-02"}, "profile_binding": {"$ref": "#/$defs/profileOn"}, "metric_population_flags": {"$ref": "#/$defs/flagsExplicitResume"}}}]},
        {"allOf": [{"$ref": "#/$defs/bindingRecord"}, {"properties": {"slot_id": {"const": "phased-03"}, "profile_binding": {"$ref": "#/$defs/profileOn"}, "metric_population_flags": {"$ref": "#/$defs/flagsExplicitResume"}}}]},
        {"allOf": [{"$ref": "#/$defs/bindingRecord"}, {"properties": {"slot_id": {"const": "phased-04"}, "profile_binding": {"$ref": "#/$defs/profileOn"}, "metric_population_flags": {"$ref": "#/$defs/flagsExplicitResume"}}}]},
        {"allOf": [{"$ref": "#/$defs/bindingRecord"}, {"properties": {"slot_id": {"const": "phased-05"}, "profile_binding": {"$ref": "#/$defs/profileOn"}, "metric_population_flags": {"$ref": "#/$defs/flagsResumeOnly"}}}]},
        {"allOf": [{"$ref": "#/$defs/bindingRecord"}, {"properties": {"slot_id": {"const": "phased-06"}, "profile_binding": {"$ref": "#/$defs/profileOn"}, "metric_population_flags": {"$ref": "#/$defs/flagsResumeOnly"}}}]},
        {"allOf": [{"$ref": "#/$defs/bindingRecord"}, {"properties": {"slot_id": {"const": "phased-07"}, "profile_binding": {"$ref": "#/$defs/profileOn"}, "metric_population_flags": {"$ref": "#/$defs/flagsResumeOnly"}}}]},
        {"allOf": [{"$ref": "#/$defs/bindingRecord"}, {"properties": {"slot_id": {"const": "phased-08"}, "profile_binding": {"$ref": "#/$defs/profileOn"}, "metric_population_flags": {"$ref": "#/$defs/flagsResumeOnly"}}}]},
        {"allOf": [{"$ref": "#/$defs/bindingRecord"}, {"properties": {"slot_id": {"const": "goal-01"}, "profile_binding": {"$ref": "#/$defs/profileOff"}, "metric_population_flags": {"$ref": "#/$defs/flagsNoExplicit"}}}]},
        {"allOf": [{"$ref": "#/$defs/bindingRecord"}, {"properties": {"slot_id": {"const": "goal-02"}, "profile_binding": {"$ref": "#/$defs/profileOff"}, "metric_population_flags": {"$ref": "#/$defs/flagsNoExplicit"}}}]},
        {"allOf": [{"$ref": "#/$defs/bindingRecord"}, {"properties": {"slot_id": {"const": "goal-03"}, "profile_binding": {"$ref": "#/$defs/profileOff"}, "metric_population_flags": {"$ref": "#/$defs/flagsNoExplicit"}}}]},
        {"allOf": [{"$ref": "#/$defs/bindingRecord"}, {"properties": {"slot_id": {"const": "goal-04"}, "profile_binding": {"$ref": "#/$defs/profileOff"}, "metric_population_flags": {"$ref": "#/$defs/flagsNoExplicit"}}}]},
        {"allOf": [{"$ref": "#/$defs/bindingRecord"}, {"properties": {"slot_id": {"const": "goal-05"}, "profile_binding": {"$ref": "#/$defs/profileOff"}, "metric_population_flags": {"$ref": "#/$defs/flagsResumeOnly"}}}]},
        {"allOf": [{"$ref": "#/$defs/bindingRecord"}, {"properties": {"slot_id": {"const": "goal-06"}, "profile_binding": {"$ref": "#/$defs/profileOff"}, "metric_population_flags": {"$ref": "#/$defs/flagsResumeOnly"}}}]}
      ],
      "items": false
    },
    "binding_manifest_commitment": {
      "$ref": "#/$defs/hmacCommitment"
    },
    "task_set_commitment": {
      "$ref": "#/$defs/hmacCommitment"
    },
    "reviewer_attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewer_id",
        "attested_at",
        "reviewed_before_task_1",
        "real_task_status_human_reviewed",
        "commitments_verified_with_run_secret",
        "reviewer_attestation_commitment"
      ],
      "properties": {
        "reviewer_id": {
          "type": "string",
          "pattern": "^reviewer:[A-Za-z0-9_-]{12,128}$"
        },
        "attested_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$",
          "format": "date-time"
        },
        "reviewed_before_task_1": {
          "const": true
        },
        "real_task_status_human_reviewed": {
          "const": true
        },
        "commitments_verified_with_run_secret": {
          "const": true
        },
        "reviewer_attestation_commitment": {
          "$ref": "#/$defs/hmacCommitment"
        }
      }
    }
  },
  "$defs": {
    "sha256Digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "hmacCommitment": {
      "type": "string",
      "pattern": "^hmac-sha256:[0-9a-f]{64}$"
    },
    "profileOff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile_backed"],
      "properties": {
        "profile_backed": {"const": false}
      }
    },
    "profileOn": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_backed",
        "profile_id",
        "profile_revision_digest",
        "profile_identity_commitment"
      ],
      "properties": {
        "profile_backed": {"const": true},
        "profile_id": {
          "type": "string",
          "pattern": "^profile:[A-Za-z0-9_-]{16,128}$"
        },
        "profile_revision_digest": {
          "$ref": "#/$defs/sha256Digest"
        },
        "profile_identity_commitment": {
          "$ref": "#/$defs/hmacCommitment"
        }
      }
    },
    "flagsNoExplicit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manual_envelope", "no_explicit_skill", "explicit_lock", "router_local_resume"],
      "properties": {
        "manual_envelope": {"const": true},
        "no_explicit_skill": {"const": true},
        "explicit_lock": {"const": false},
        "router_local_resume": {"const": false}
      }
    },
    "flagsExplicitResume": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manual_envelope", "no_explicit_skill", "explicit_lock", "router_local_resume"],
      "properties": {
        "manual_envelope": {"const": true},
        "no_explicit_skill": {"const": false},
        "explicit_lock": {"const": true},
        "router_local_resume": {"const": true}
      }
    },
    "flagsResumeOnly": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manual_envelope", "no_explicit_skill", "explicit_lock", "router_local_resume"],
      "properties": {
        "manual_envelope": {"const": true},
        "no_explicit_skill": {"const": false},
        "explicit_lock": {"const": false},
        "router_local_resume": {"const": true}
      }
    },
    "bindingRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot_id",
        "task_identity",
        "task_identity_commitment",
        "source_identity",
        "source_identity_commitment",
        "profile_binding",
        "metric_population_flags",
        "record_integrity_commitment"
      ],
      "properties": {
        "slot_id": {
          "type": "string"
        },
        "task_identity": {
          "type": "string",
          "pattern": "^task:[A-Za-z0-9_-]{16,128}$"
        },
      "task_identity_commitment": {
        "type": "string",
        "pattern": "^hmac-sha256:[0-9a-f]{64}$"
        },
        "source_identity": {
          "type": "string",
          "pattern": "^source:[A-Za-z0-9_-]{16,128}$",
          "description": "Opaque task-specific source snapshot or brief identity; never a shared repository identity."
        },
      "source_identity_commitment": {
        "type": "string",
        "pattern": "^hmac-sha256:[0-9a-f]{64}$"
        },
        "profile_binding": {
          "oneOf": [
            {"$ref": "#/$defs/profileOff"},
            {"$ref": "#/$defs/profileOn"}
          ]
        },
        "metric_population_flags": {
          "oneOf": [
            {"$ref": "#/$defs/flagsNoExplicit"},
            {"$ref": "#/$defs/flagsExplicitResume"},
            {"$ref": "#/$defs/flagsResumeOnly"}
          ]
        },
      "record_integrity_commitment": {
        "type": "string",
        "pattern": "^hmac-sha256:[0-9a-f]{64}$"
        }
      }
    }
  }
}
