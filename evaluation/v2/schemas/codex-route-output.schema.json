{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workflow-skill-router.dev/schemas/v2/codex-route-output.schema.json",
  "title": "Codex routing decision",
  "type": "object",
  "required": [
    "envelope",
    "selection_mode",
    "primary_skill",
    "support_skills",
    "consent_action",
    "goal_relation",
    "rationale",
    "evaluation_evidence"
  ],
  "properties": {
    "envelope": { "enum": ["single", "phased", "managed-goal"] },
    "selection_mode": { "enum": ["auto", "explicit-locked"] },
    "primary_skill": { "type": "string", "minLength": 1, "maxLength": 256 },
    "support_skills": {
      "type": "array",
      "maxItems": 8,
      "items": { "type": "string", "minLength": 1, "maxLength": 256 }
    },
    "consent_action": {
      "enum": ["not-required", "proposal-required", "approved", "rejected"]
    },
    "goal_relation": {
      "enum": ["none", "progress", "status", "steer", "side-question"]
    },
    "rationale": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "evaluation_evidence": {
      "description": "Required public-safe Contract 2.3.0 observations. Never include prompts, instructions, profile contents, paths, or scoring expectations.",
      "type": "object",
      "required": [
        "classification",
        "authority",
        "profile_explain",
        "activation_status",
        "semantic_candidate_persisted"
      ],
      "properties": {
        "classification": {
          "type": "object",
          "required": ["source", "reason_codes"],
          "properties": {
            "source": {
              "enum": [
                "native-goal-binding",
                "caller-work-mode-hint",
                "deterministic-analyzer",
                "profile-route",
                "builtin-fallback",
                "legacy-replay"
              ]
            },
            "reason_codes": {
              "type": "array",
              "maxItems": 8,
              "items": {
                "enum": [
                  "single-default",
                  "explicit-skill-lock",
                  "multi-stage-sequence",
                  "phase-transition-signal",
                  "explicit-phased-signal",
                  "cross-repository-signal",
                  "resumable-signal",
                  "dependency-signal",
                  "managed-goal-evidence",
                  "goal-status-query",
                  "goal-steer-request",
                  "goal-side-question",
                  "capability-unavailable",
                  "runtime-drift-revalidation"
                ]
              }
            }
          },
          "additionalProperties": false
        },
        "authority": {
          "type": "object",
          "required": ["mode", "native_goal_mutated"],
          "properties": {
            "mode": { "enum": ["router-local"] },
            "native_goal_mutated": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "profile_explain": {
          "type": "object",
          "required": ["status", "reason_codes"],
          "properties": {
            "status": { "enum": ["not-requested", "match", "miss"] },
            "reason_codes": {
              "type": "array",
              "maxItems": 8,
              "items": { "enum": ["objective-keyword-miss"] }
            }
          },
          "additionalProperties": false
        },
        "activation_status": { "enum": ["unverified"] },
        "semantic_candidate_persisted": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
