{
  "repository": "eric861129/Workflow-skill-router",
  "branch": "main",
  "required_status_checks": {
    "strict": true,
    "checks": [
      {
        "workflow": ".github/workflows/validate.yml",
        "job": "validate",
        "context": "Core, documentation, and policy contracts",
        "app_id": 15368
      },
      {
        "workflow": ".github/workflows/validate.yml",
        "job": "site-visual",
        "context": "Site visual regression",
        "app_id": 15368
      },
      {
        "workflow": ".github/workflows/validate.yml",
        "job": "required-v2",
        "context": "Required cross-platform V2 gate",
        "app_id": 15368
      }
    ]
  },
  "required_branch_controls": {
    "pull_request": true,
    "conversation_resolution": true,
    "force_pushes": false,
    "deletions": false
  },
  "tag_protection": {
    "name": "Immutable V2 release tags",
    "target": "tag",
    "enforcement": "active",
    "ref_name_include": "refs/tags/v2.*",
    "required_rules": ["creation", "update", "deletion"],
    "required_bypass_actor": {
      "actor_id": 15368,
      "actor_type": "Integration",
      "bypass_mode": "always"
    }
  }
}
